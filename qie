#!/usr/bin/env python3
import base64
import binascii
import errno
import json
import os
import re
import shutil
import socket
import subprocess
import sys
import time

CDIR = '/etc/s-box'
CRUN = CDIR + '/sb.json'
STATE = CDIR + '/qie_state'
NODES_DIR = CDIR + '/qie_nodes'
INDEX = CDIR + '/qie_nodes.json'
CDIRECT = CDIR + '/sb_direct.json'

BEGIN = 'QIE_NODE_BEGIN'
END = 'QIE_NODE_END'

REMOTE_TYPES = {
    'hysteria',
    'hysteria2',
    'hy2',
    'tuic',
    'trojan',
    'vmess',
    'vless',
    'shadowsocks',
    'socks',
    'http',
    'ssh',
}


def die(msg):
    print(msg)
    sys.exit(1)


def load_json(path):
    with open(path, 'r', encoding='utf-8') as f:
        return json.load(f)


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + '.tmp'
    with open(tmp, 'w', encoding='utf-8', newline='\n') as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
        f.write('\n')
    os.replace(tmp, path)


def atomic_copy(src, dst):
    os.makedirs(os.path.dirname(dst), exist_ok=True)
    tmp = dst + '.tmp'
    shutil.copy2(src, tmp)
    os.replace(tmp, dst)


def slugify(name):
    s = re.sub(r'[^A-Za-z0-9._-]+', '-', name.strip())
    s = s.strip('.-_').lower()
    return s or 'node'


def find_singbox():
    candidates = [
        shutil.which('sing-box'),
        '/usr/local/bin/sing-box',
        '/usr/bin/sing-box',
        '/bin/sing-box',
        '/opt/sing-box/sing-box',
        '/etc/s-box/sing-box',
    ]

    for p in candidates:
        if p and os.path.exists(p) and os.access(p, os.X_OK):
            return p

    return None


def validate_json(path):
    try:
        load_json(path)
        return True
    except Exception as e:
        print(f'JSON 校验失败: {path} - {e}')
        return False


def validate_config(path):
    if not validate_json(path):
        return False

    sb = find_singbox()
    if not sb:
        print('提示: 未找到 sing-box，跳过 sing-box check')
        return True

    r = subprocess.run(
        [sb, 'check', '-c', path],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )

    if r.returncode != 0:
        print(f'sing-box 配置校验失败: {path}')
        msg = (r.stderr or r.stdout or '').strip()
        if msg:
            print(msg)
        return False

    return True


def load_index():
    if not os.path.exists(INDEX):
        return []

    try:
        data = load_json(INDEX)
    except Exception:
        return []

    nodes = data.get('nodes', data if isinstance(data, list) else [])
    if not isinstance(nodes, list):
        return []

    clean = []
    for node in nodes:
        if isinstance(node, dict) and node.get('id') and node.get('config'):
            clean.append(node)
    return clean


def save_index(nodes):
    save_json(INDEX, {'nodes': nodes})


def get_node(node_id):
    for node in load_index():
        if node['id'] == node_id:
            return node
    return None


def find_node(key):
    key = key.strip().lower()
    nodes = load_index()
    matches = []
    for node in nodes:
        if node['id'].lower() == key or node.get('name', '').lower() == key:
            return node
        if node['id'].lower().startswith(key) or node.get('name', '').lower().startswith(key):
            matches.append(node)

    if len(matches) == 1:
        return matches[0]

    return None


def get_state():
    if not os.path.exists(STATE):
        return None

    try:
        state = open(STATE, encoding='utf-8').read().strip()
    except Exception:
        return None

    if state == 'DIRECT':
        return state

    if get_node(state):
        return state

    return None


def save_state(state):
    os.makedirs(CDIR, exist_ok=True)
    with open(STATE, 'w', encoding='utf-8', newline='\n') as f:
        f.write(state)


def split_host_port(server):
    if not isinstance(server, str):
        return None, None

    s = server.strip()
    if s.startswith('[') and ']' in s:
        host = s[1:s.index(']')]
        rest = s[s.index(']') + 1:]
        if rest.startswith(':'):
            try:
                return host, int(rest[1:])
            except ValueError:
                return host, None
        return host, None

    if ':' in s and s.count(':') == 1:
        host, port = s.rsplit(':', 1)
        try:
            return host, int(port)
        except ValueError:
            return s, None

    return s, None


def endpoint_from_outbound(outbound):
    if not isinstance(outbound, dict):
        return None

    typ = outbound.get('type')
    if typ not in REMOTE_TYPES:
        return None

    server = outbound.get('server')
    port = outbound.get('server_port')

    if server is None:
        return None

    host, embedded_port = split_host_port(server)
    if port is None:
        port = embedded_port

    try:
        port = int(port)
    except Exception:
        return None

    if not host or not port:
        return None

    return {
        'host': host,
        'port': port,
        'type': typ,
        'tag': outbound.get('tag', ''),
    }


def detect_endpoint_from_data(data):
    outs = data.get('outbounds', [])
    if not isinstance(outs, list):
        return None

    by_tag = {}
    for o in outs:
        if isinstance(o, dict) and o.get('tag'):
            by_tag[o['tag']] = o

    preferred = []
    route = data.get('route', {})
    if isinstance(route, dict):
        final = route.get('final')
        if isinstance(final, str) and final in by_tag:
            preferred.append(by_tag[final])

            final_out = by_tag[final]
            if isinstance(final_out, dict) and isinstance(final_out.get('outbounds'), list):
                for tag in final_out['outbounds']:
                    if tag in by_tag:
                        preferred.append(by_tag[tag])

    preferred.extend(outs)

    seen = set()
    for o in preferred:
        if not isinstance(o, dict):
            continue
        key = id(o)
        if key in seen:
            continue
        seen.add(key)

        ep = endpoint_from_outbound(o)
        if ep:
            return ep

    return None


def detect_endpoint_from_config(path):
    try:
        return detect_endpoint_from_data(load_json(path))
    except Exception:
        return None


def endpoint_text(endpoint):
    if not endpoint:
        return '未识别'

    suffix = endpoint.get('type', '')
    if endpoint.get('tag'):
        suffix += '/' + endpoint['tag']

    return f"{endpoint['host']}:{endpoint['port']} [{suffix}]"


def node_label(node):
    ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
    if ep:
        return f"{node.get('name', node['id'])} ({ep['host']}:{ep['port']})"
    return node.get('name', node['id'])


def tcp_latency(host, port, timeout=2.0, samples=3):
    times = []

    for _ in range(samples):
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(timeout)
        start = time.monotonic()

        try:
            err = s.connect_ex((host, port))
            cost = (time.monotonic() - start) * 1000
            if err == 0:
                times.append(cost)
        except OSError as e:
            if e.errno not in (
                errno.EHOSTUNREACH,
                errno.ENETUNREACH,
                errno.ECONNREFUSED,
                errno.ETIMEDOUT,
            ):
                pass
        finally:
            s.close()

    if not times:
        return None

    return sum(times) / len(times)


def fmt_latency(v):
    if v is None:
        return 'TCP: 超时'
    return f'TCP: {v:.0f}ms'


def has_direct_outbound(data):
    outs = data.get('outbounds', [])
    if not isinstance(outs, list):
        return False

    return any(
        isinstance(o, dict) and o.get('tag') == 'direct'
        for o in outs
    )


def make_direct(data):
    if 'outbounds' not in data or not isinstance(data['outbounds'], list):
        data['outbounds'] = []

    if not has_direct_outbound(data):
        data['outbounds'].append({
            'type': 'direct',
            'tag': 'direct',
        })

    if 'route' not in data or not isinstance(data['route'], dict):
        data['route'] = {}

    data['route']['rules'] = []
    data['route']['final'] = 'direct'

    return data


def ensure_direct_config():
    if os.path.exists(CDIRECT):
        if not validate_config(CDIRECT):
            die('错误: sb_direct.json 已存在但不合法，请手动修复')
        return

    if not os.path.exists(CRUN):
        die('错误: 当前没有运行配置，无法生成 Direct 配置')

    if not validate_json(CRUN):
        die('错误: 当前运行配置 JSON 不合法，无法生成 Direct 配置')

    data = make_direct(load_json(CRUN))
    save_json(CDIRECT, data)

    if not validate_config(CDIRECT):
        os.remove(CDIRECT)
        die('错误: 自动创建的 Direct 配置不合法，已删除')

    print('已创建 Direct 配置: ' + CDIRECT)


def restart_sb():
    subprocess.run(
        ['systemctl', 'restart', 'sing-box'],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    for _ in range(6):
        time.sleep(0.5)
        r = subprocess.run(
            ['systemctl', 'is-active', 'sing-box'],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        if r.stdout.strip() == 'active':
            return True

    return False


def service_status():
    r = subprocess.run(
        ['systemctl', 'is-active', 'sing-box'],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    return r.stdout.strip()


def switch_to_path(state, label, src):
    if not os.path.exists(src):
        die('错误: 配置文件不存在 - ' + src)

    if not validate_config(src):
        die('错误: 目标配置不合法，放弃切换')

    rollback = None
    if os.path.exists(CRUN):
        if not validate_json(CRUN):
            die('错误: 当前运行配置 JSON 不合法，放弃切换')
        rollback = CRUN + '.rollback'
        shutil.copy2(CRUN, rollback)

    print('切换至 ' + label + ' ...', end=' ', flush=True)
    atomic_copy(src, CRUN)

    if restart_sb():
        save_state(state)
        print('OK')
        if rollback and os.path.exists(rollback):
            os.remove(rollback)
        return

    print('失败，回滚中...')

    if rollback and os.path.exists(rollback):
        atomic_copy(rollback, CRUN)
        os.remove(rollback)
        if restart_sb():
            print('已回滚到原配置')
        else:
            print('严重错误: 回滚后 sing-box 仍未启动')
            print('建议执行: systemctl status sing-box --no-pager -l')
    else:
        try:
            os.remove(CRUN)
        except FileNotFoundError:
            pass
        print('没有可回滚的原配置，已移除失败配置')

    sys.exit(1)


def switch_node(node):
    switch_to_path(node['id'], node_label(node), node['config'])


def switch_direct():
    ensure_direct_config()
    switch_to_path('DIRECT', 'Direct', CDIRECT)


def read_import_block():
    print('请粘贴落地机生成的数据块，以 QIE_NODE_BEGIN 开头，以 QIE_NODE_END 结尾。')
    print('粘贴完成后回车；检测到结束标记会自动导入。')

    lines = []
    started = False

    while True:
        try:
            line = input()
        except EOFError:
            break
        except KeyboardInterrupt:
            print()
            die('已取消')

        text = line.strip()
        if text == BEGIN:
            started = True
            lines = []
            continue

        if text == END:
            if not started:
                die('错误: 未找到开始标记')
            return ''.join(lines)

        if started:
            lines.append(text)

    die('错误: 未读取到完整的数据块')


def decode_import_payload(encoded):
    try:
        raw = base64.b64decode(encoded.encode('ascii'), validate=True)
        data = json.loads(raw.decode('utf-8'))
    except (binascii.Error, UnicodeDecodeError, json.JSONDecodeError) as e:
        die('错误: 导入数据无法解析 - ' + str(e))

    if not isinstance(data, dict):
        die('错误: 导入数据格式不正确')

    if data.get('format') != 'qie-node' or int(data.get('version', 0)) != 1:
        die('错误: 不支持的导入数据格式')

    config = data.get('config')
    if not isinstance(config, dict):
        die('错误: 导入数据缺少 sing-box 配置')

    name = str(data.get('name') or '').strip()
    if not name:
        name = 'node'

    return name, config


def unique_node_id(base, nodes):
    existing = {node['id'] for node in nodes}
    node_id = slugify(base)
    if node_id not in existing:
        return node_id

    i = 2
    while f'{node_id}-{i}' in existing:
        i += 1
    return f'{node_id}-{i}'


def import_node():
    encoded = read_import_block()
    name, config = decode_import_payload(encoded)

    nodes = load_index()
    node_id = unique_node_id(name, nodes)
    config_path = os.path.join(NODES_DIR, node_id + '.json')

    save_json(config_path, config)
    if not validate_config(config_path):
        os.remove(config_path)
        die('错误: 导入配置未通过校验，已放弃')

    endpoint = detect_endpoint_from_data(config)
    node = {
        'id': node_id,
        'name': name,
        'config': config_path,
        'endpoint': endpoint,
        'created_at': time.strftime('%Y-%m-%dT%H:%M:%S%z'),
    }
    nodes.append(node)
    save_index(nodes)

    print('已导入落地机: ' + node_label(node))
    print('配置文件: ' + config_path)


def ensure_has_nodes_or_import():
    if load_index():
        return

    print('当前没有任何落地机配置。')
    print('请先在落地机 SSH 中执行 README 的导出命令，复制生成的数据块。')
    import_node()


def print_nodes():
    nodes = load_index()
    if not nodes:
        print('暂无落地机配置')
        return

    cur = get_state()
    for i, node in enumerate(nodes, 1):
        mark = '*' if cur == node['id'] else ' '
        ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
        print(f"{mark} {i}. {node['id']}  {node_label(node)}  {endpoint_text(ep)}")


def print_test():
    nodes = load_index()
    if not nodes:
        print('暂无落地机配置')
        return

    print('========================')
    print(' 节点 TCP 测速')
    print('========================')

    for node in nodes:
        ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
        latency = None
        if ep:
            latency = tcp_latency(ep['host'], ep['port'])
        print(f" {node['id']:<18} {endpoint_text(ep):<36} {fmt_latency(latency)}")


def print_status():
    cur = get_state()
    print('========================')
    print(' 当前状态')
    print('========================')

    if cur == 'DIRECT':
        print('当前模式: Direct')
    elif cur:
        node = get_node(cur)
        print('当前模式: ' + node_label(node))
    else:
        print('当前模式: 未设置')

    print('sing-box: ' + service_status())

    sb = find_singbox()
    if sb:
        print('sing-box bin: ' + sb)
    else:
        print('sing-box bin: 未找到')

    print('节点数量: ' + str(len(load_index())))


def print_menu():
    ensure_has_nodes_or_import()
    nodes = load_index()
    cur = get_state()

    print('========================')
    if cur == 'DIRECT':
        print(' 当前: Direct')
    elif cur and get_node(cur):
        print(' 当前: ' + node_label(get_node(cur)))
    else:
        print(' 当前: 未设置')
    print(' sing-box: ' + service_status())
    print('========================')

    for i, node in enumerate(nodes, 1):
        print(f" {i}. {node_label(node)}")

    print(' a. 录入落地机')
    print(' d. Direct')
    print(' s. Status')
    print(' t. Test')
    print(' 0. Exit')
    print('========================')

    try:
        ch = input('选择: ').strip().lower()
    except (EOFError, KeyboardInterrupt):
        ch = '0'

    if ch.isdigit() and ch != '0':
        idx = int(ch) - 1
        if 0 <= idx < len(nodes):
            switch_node(nodes[idx])
            return
        die('错误: 无效选择')
    elif ch in ('a', 'add', 'import'):
        import_node()
    elif ch in ('d', 'direct', 'dir'):
        switch_direct()
    elif ch in ('s', 'st', 'status'):
        print_status()
    elif ch in ('t', 'test'):
        print_test()
    else:
        print('Bye.')


def usage():
    print('用法:')
    print('  qie')
    print('  qie add|import')
    print('  qie list')
    print('  qie <节点编号或名称>')
    print('  qie direct')
    print('  qie status')
    print('  qie test')


def main():
    if os.geteuid() != 0:
        die('错误: 请用 root 执行')

    os.makedirs(CDIR, exist_ok=True)
    os.makedirs(NODES_DIR, exist_ok=True)

    if len(sys.argv) == 1:
        print_menu()
        return

    arg = sys.argv[1].strip()
    low = arg.lower()

    if low in ('add', 'import', 'a'):
        import_node()
    elif low in ('list', 'ls'):
        print_nodes()
    elif low in ('direct', 'dir', 'd'):
        switch_direct()
    elif low in ('status', 'st', 's'):
        print_status()
    elif low in ('test', 't'):
        print_test()
    elif low in ('help', '-h', '--help'):
        usage()
    else:
        node = None
        if low.isdigit():
            nodes = load_index()
            idx = int(low) - 1
            if 0 <= idx < len(nodes):
                node = nodes[idx]
        if not node:
            node = find_node(arg)
        if not node:
            die('错误: 未找到节点 - ' + arg)
        switch_node(node)


if __name__ == '__main__':
    main()
