def print_menu():
    ensure_has_nodes_or_import()
    nodes = load_index()
    cur = get_state()

    print('========================')
    print(' QIE ' + VERSION)
    if cur == 'DIRECT':
        print(' 当前: 直连')
    elif cur and get_node(cur):
        print(' 当前: ' + node_label(get_node(cur)))
    else:
        print(' 当前: 未设置')
    print(' sing-box: ' + service_status())
    print('========================')

    for i, node in enumerate(nodes, 1):
        ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
        print(f" {i}. {node_label(node)}  {test_protocol_text(node, ep)}  {node_latency_text(node)}")

    print(' a. 录入落地机')
    print(' r. 重命名落地机')
    print(' x. 删除落地机')
    print(' d. 直连')
    print(' s. 状态')
    print(' t. 测速')
    print(' 0. 退出')
    print('========================')

    try:
        ch = input('选择: ').strip().lower()
    except (EOFError, KeyboardInterrupt):
        ch = '0'

    if ch.isdigit() and ch != '0':
        idx = int(ch) - 1
        if 0 <= idx < len(nodes):
            switch_node(nodes[idx])
            return
        die('错误: 无效选择')
    elif ch in ('a', 'add', 'import'):
        import_node()
    elif ch in ('r', 'rename'):
        rename_node()
    elif ch in ('x', 'delete', 'del', 'remove', 'rm'):
        delete_node()
    elif ch in ('d', 'direct', 'dir'):
        switch_direct()
    elif ch in ('s', 'st', 'status'):
        print_status()
    elif ch in ('t', 'test'):
        print_test()
    else:
        print('已退出。')


