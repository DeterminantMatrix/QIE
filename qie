    for node in nodes:
        ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
        latency = None
        protocol = node_test_protocol(node, ep)
        if ep:
            latency = measure_latency(ep['host'], ep['port'], protocol)
        parts = [
            f" {node['id']:<18}",
            f"{endpoint_text(ep):<36}",
