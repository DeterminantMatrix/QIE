def main():
    if len(sys.argv) > 1 and sys.argv[1].strip().lower() in ('version', '-v', '--version'):
        print('QIE ' + VERSION)
        return

    if os.geteuid() != 0:
        die('错误: 请用 root 执行')

    os.makedirs(CDIR, exist_ok=True)
    os.makedirs(NODES_DIR, exist_ok=True)

    if len(sys.argv) == 1:
        print_menu()
        return

    arg = sys.argv[1].strip()
    low = arg.lower()

    if low in ('add', 'import', 'a'):
        import_node()
    elif low in ('list', 'ls'):
        print_nodes()
    elif low in ('rename', 'ren', 'r'):
        key = sys.argv[2].strip() if len(sys.argv) > 2 else None
        new_name = ' '.join(sys.argv[3:]).strip() if len(sys.argv) > 3 else None
        rename_node(key, new_name)
    elif low in ('delete', 'del', 'remove', 'rm', 'x'):
        key = sys.argv[2].strip() if len(sys.argv) > 2 else None
        delete_node(key)
    elif low in ('direct', 'dir', 'd'):
        switch_direct()
    elif low in ('status', 'st', 's'):
        print_status()
    elif low in ('test', 't'):
        print_test()
    elif low in ('help', '-h', '--help'):
        usage()
    else:
        node = None
        if low.isdigit():
            nodes = load_index()
            idx = int(low) - 1
            if 0 <= idx < len(nodes):
                node = nodes[idx]
        if not node:
            node = find_node(arg)
        if not node:
            die('错误: 未找到节点 - ' + arg)
        switch_node(node)


if __name__ == '__main__':
    main()
