def read_import_block():
    print('请粘贴落地机生成的数据块，以 QIE_NODE_BEGIN 开头，以 QIE_NODE_END 结尾。')
    print('粘贴完成后回车；检测到结束标记会自动导入。')

    lines = []
    started = False

    while True:
        try:
            line = input()
        except EOFError:
            break
        except KeyboardInterrupt:
            print()
            die('已取消')

        text = line.strip()
        if text == BEGIN:
            started = True
            lines = []
            continue

        if text == END:
            if not started:
                die('错误: 未找到开始标记')
            return ''.join(lines)

        if started:
            lines.append(text)

    die('错误: 未读取到完整的数据块')


def decode_import_payload(encoded):
    try:
        raw = base64.b64decode(encoded.encode('ascii'), validate=True)
        data = json.loads(raw.decode('utf-8'))
    except (binascii.Error, UnicodeDecodeError, json.JSONDecodeError) as e:
        die('错误: 导入数据无法解析 - ' + str(e))

    if not isinstance(data, dict):
        die('错误: 导入数据格式不正确')

    if data.get('format') != 'qie-node' or int(data.get('version', 0)) != 1:
        die('错误: 不支持的导入数据格式')

    config = data.get('config')
    if not isinstance(config, dict):
        die('错误: 导入数据缺少 sing-box 配置')

    name = str(data.get('name') or '').strip()
    if not name:
        name = 'node'

    test_protocol = str(data.get('test_protocol') or '').strip().lower()
    if test_protocol not in ('tcp', 'udp'):
        endpoint = detect_endpoint_from_data(config)
        test_protocol = infer_test_protocol(endpoint)

    return name, config, test_protocol


def unique_node_id(base, nodes):
    existing = {node['id'] for node in nodes}
    node_id = slugify(base)
    if node_id not in existing:
        return node_id

    i = 2
    while f'{node_id}-{i}' in existing:
        i += 1
    return f'{node_id}-{i}'


def import_node():
    cleanup_qie_residue()
    encoded = read_import_block()
    name, config, test_protocol = decode_import_payload(encoded)

    nodes = load_index()
    node_id = unique_node_id(name, nodes)
    config_path = os.path.join(NODES_DIR, node_id + '.json')

    save_json(config_path, config)
    if not validate_config(config_path):
        os.remove(config_path)
        cleanup_qie_residue()
        die('错误: 导入配置未通过校验，已放弃')

    endpoint = detect_endpoint_from_data(config)
    node = {
        'id': node_id,
        'name': name,
        'config': config_path,
        'endpoint': endpoint,
        'test_protocol': test_protocol,
        'created_at': time.strftime('%Y-%m-%dT%H:%M:%S%z'),
    }
    nodes.append(node)
    save_index(nodes)

    print('已导入落地机: ' + node_label(node))
    print('配置文件: ' + config_path)
    cleanup_qie_residue()


