def die(msg):
    print(msg)
    sys.exit(1)


def load_json(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        return json.load(f)


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + '.tmp'
    with open(tmp, 'w', encoding='utf-8', newline='\n') as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
        f.write('\n')
    os.replace(tmp, path)


def cleanup_qie_residue():
    targets = []
    for root in (CDIR, NODES_DIR):
        if not os.path.isdir(root):
            continue
        for name in os.listdir(root):
            if (
                name.endswith('.tmp')
                or name.endswith('.rollback')
                or name.endswith('.qie.bak')
            ):
                targets.append(os.path.join(root, name))

    for path in targets:
        try:
            if os.path.isfile(path) or os.path.islink(path):
                os.remove(path)
        except OSError:
            pass


def atomic_copy(src, dst):
    os.makedirs(os.path.dirname(dst), exist_ok=True)
    tmp = dst + '.tmp'
    shutil.copy2(src, tmp)
    os.replace(tmp, dst)


def slugify(name):
    s = re.sub(r'[^A-Za-z0-9._-]+', '-', name.strip())
    s = s.strip('.-_').lower()
    return s or 'node'


def find_singbox():
    candidates = [
        shutil.which('sing-box'),
        '/usr/local/bin/sing-box',
        '/usr/bin/sing-box',
        '/bin/sing-box',
        '/opt/sing-box/sing-box',
        '/etc/s-box/sing-box',
    ]

    for p in candidates:
        if p and os.path.exists(p) and os.access(p, os.X_OK):
            return p

    return None


def validate_json(path):
    try:
        load_json(path)
        return True
    except Exception as e:
        print(f'JSON 校验失败: {path} - {e}')
        return False


def validate_config(path):
    if not validate_json(path):
        return False

    sb = find_singbox()
    if not sb:
        print('提示: 未找到 sing-box，跳过 sing-box check')
        return True

    r = subprocess.run(
        [sb, 'check', '-c', path],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )

    if r.returncode != 0:
        print(f'sing-box 配置校验失败: {path}')
        msg = (r.stderr or r.stdout or '').strip()
        if msg:
            print(msg)
        return False

    return True


def load_index():
    if not os.path.exists(INDEX):
        return []

    try:
        data = load_json(INDEX)
    except Exception:
        return []

    nodes = data.get('nodes', data if isinstance(data, list) else [])
    if not isinstance(nodes, list):
        return []

    clean = []
    for node in nodes:
        if isinstance(node, dict) and node.get('id') and node.get('config'):
            clean.append(node)
    return clean


def save_index(nodes):
    save_json(INDEX, {'nodes': nodes})


def get_node(node_id):
    for node in load_index():
        if node['id'] == node_id:
            return node
    return None


def find_node(key):
    key = key.strip().lower()
    nodes = load_index()
    matches = []
    for node in nodes:
        if node['id'].lower() == key or node.get('name', '').lower() == key:
            return node
        if node['id'].lower().startswith(key) or node.get('name', '').lower().startswith(key):
            matches.append(node)

    if len(matches) == 1:
        return matches[0]

    return None


def get_state():
    if not os.path.exists(STATE):
        return None

    try:
        state = open(STATE, encoding='utf-8').read().strip()
    except Exception:
        return None

    if state == 'DIRECT':
        return state

    if get_node(state):
        return state

    return None


def save_state(state):
    os.makedirs(CDIR, exist_ok=True)
    with open(STATE, 'w', encoding='utf-8', newline='\n') as f:
        f.write(state)


def split_host_port(server):
    if not isinstance(server, str):
        return None, None

    s = server.strip()
    if s.startswith('[') and ']' in s:
        host = s[1:s.index(']')]
        rest = s[s.index(']') + 1:]
        if rest.startswith(':'):
            try:
                return host, int(rest[1:])
            except ValueError:
                return host, None
        return host, None

    if ':' in s and s.count(':') == 1:
        host, port = s.rsplit(':', 1)
        try:
            return host, int(port)
        except ValueError:
            return s, None

    return s, None


def endpoint_from_outbound(outbound):
    if not isinstance(outbound, dict):
        return None

    typ = outbound.get('type')
    if typ not in REMOTE_TYPES:
        return None

    server = outbound.get('server')
    port = outbound.get('server_port')

    if server is None:
        return None

    host, embedded_port = split_host_port(server)
    if port is None:
        port = embedded_port

    try:
        port = int(port)
    except Exception:
        return None

    if not host or not port:
        return None

    return {
        'host': host,
        'port': port,
        'type': typ,
        'tag': outbound.get('tag', ''),
    }


def detect_endpoint_from_data(data):
    outs = data.get('outbounds', [])
    if not isinstance(outs, list):
        return None

    by_tag = {}
    for o in outs:
        if isinstance(o, dict) and o.get('tag'):
            by_tag[o['tag']] = o

    preferred = []
    route = data.get('route', {})
    if isinstance(route, dict):
        final = route.get('final')
        if isinstance(final, str) and final in by_tag:
            preferred.append(by_tag[final])

            final_out = by_tag[final]
            if isinstance(final_out, dict) and isinstance(final_out.get('outbounds'), list):
                for tag in final_out['outbounds']:
                    if tag in by_tag:
                        preferred.append(by_tag[tag])

    preferred.extend(outs)

    seen = set()
    for o in preferred:
        if not isinstance(o, dict):
            continue
        key = id(o)
        if key in seen:
            continue
        seen.add(key)

        ep = endpoint_from_outbound(o)
        if ep:
            return ep

    return None


def detect_endpoint_from_config(path):
    try:
        return detect_endpoint_from_data(load_json(path))
    except Exception:
        return None


def endpoint_text(endpoint):
    if not endpoint:
        return '未识别'

    suffix = endpoint.get('type', '')
    if endpoint.get('tag'):
        suffix += '/' + endpoint['tag']

    return f"{endpoint['host']}:{endpoint['port']} [{suffix}]"


def test_protocol_text(node, endpoint=None):
    return '测速=' + node_test_protocol(node, endpoint).upper()


def node_label(node):
    ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
    if ep:
        return f"{node.get('name', node['id'])} ({ep['host']}:{ep['port']})"
    return node.get('name', node['id'])


def tcp_latency(host, port, timeout=2.0, samples=3):
    times = []

    for _ in range(samples):
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(timeout)
        start = time.monotonic()

        try:
            err = s.connect_ex((host, port))
            cost = (time.monotonic() - start) * 1000
            if err == 0:
                times.append(cost)
        except OSError as e:
            if e.errno not in (
                errno.EHOSTUNREACH,
                errno.ENETUNREACH,
                errno.ECONNREFUSED,
                errno.ETIMEDOUT,
            ):
                pass
        finally:
            s.close()

    if not times:
        return None

    return sum(times) / len(times)


def fmt_latency(v):
    if v is None:
        return 'TCP: 超时'
    return f'TCP: {v:.0f}ms'


def ping_latency(host, timeout=1.0, samples=2):
    times = []
    ping = shutil.which('ping')
    if not ping:
        return None

    timeout_arg = str(max(1, int(timeout)))
    cmd = [ping]
    if ':' in host:
        cmd.append('-6')
    cmd.extend(['-c', '1', '-W', timeout_arg, host])

    for _ in range(samples):
        r = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout + 1,
        )
        if r.returncode != 0:
            continue

        m = re.search(r'time[=<]([0-9.]+)\s*ms', r.stdout)
        if m:
            times.append(float(m.group(1)))
        elif 'time<1' in r.stdout:
            times.append(0.5)

    if not times:
        return None

    return sum(times) / len(times)


def fmt_latency_by_protocol(v, protocol):
    if protocol == 'udp':
        if v is None:
            return 'ICMP: 不可用'
        return f'ICMP: {v:.0f}ms'

    prefix = 'TCP'
    if v is None:
        return prefix + ': 超时'
    return f'{prefix}: {v:.0f}ms'


def infer_test_protocol(endpoint):
    if not endpoint:
        return 'tcp'

    typ = str(endpoint.get('type') or '').strip().lower()
    if typ in ('hysteria', 'hysteria2', 'hy2', 'tuic'):
        return 'udp'

    return 'tcp'


def node_test_protocol(node, endpoint=None):
    ep = endpoint or node.get('endpoint')
    if infer_test_protocol(ep) == 'udp':
        return 'udp'

    config_ep = detect_endpoint_from_config(node['config'])
    if infer_test_protocol(config_ep) == 'udp':
        return 'udp'

    value = str(node.get('test_protocol') or '').strip().lower()
    if value in ('tcp', 'udp'):
        return value

    return infer_test_protocol(ep or config_ep)


def measure_latency(host, port, protocol, timeout=2.0, samples=3):
    if protocol == 'udp':
        return ping_latency(host, timeout=timeout, samples=samples)
    return tcp_latency(host, port, timeout=timeout, samples=samples)


def node_latency_text(node, timeout=1.0, samples=1):
    ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
    if not ep:
        return '延迟: 未识别'
    protocol = node_test_protocol(node, ep)
    latency = measure_latency(ep['host'], ep['port'], protocol, timeout=timeout, samples=samples)
    return fmt_latency_by_protocol(latency, protocol)


def free_local_port():
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.bind(('127.0.0.1', 0))
    port = s.getsockname()[1]
    s.close()
    return port


def wait_tcp_port(host, port, timeout=3.0):
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(0.2)
        try:
            if s.connect_ex((host, port)) == 0:
                return True
        finally:
            s.close()
        time.sleep(0.1)
    return False


def build_probe_config(node, listen_port):
    outbound = outbound_from_node_config(node['config'])
    outbound['tag'] = 'proxy'

    return {
        'log': {'level': 'error'},
        'inbounds': [
            {
                'type': 'mixed',
                'tag': 'mixed-in',
                'listen': '127.0.0.1',
                'listen_port': listen_port,
            }
        ],
        'outbounds': [
            outbound,
            {'type': 'direct', 'tag': 'direct'},
        ],
        'route': {'rules': [], 'final': 'proxy'},
    }


def outbound_probe_latency(node, timeout=8.0):
    sb = find_singbox()
    if not sb:
        return None, '缺 sing-box'

    curl = shutil.which('curl')
    if not curl:
        return None, '缺 curl'

    listen_port = free_local_port()
    proc = None
    with tempfile.TemporaryDirectory(prefix='qie-probe-') as d:
        config_path = os.path.join(d, 'probe.json')
        save_json(config_path, build_probe_config(node, listen_port))

        proc = subprocess.Popen(
            [sb, 'run', '-c', config_path],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        try:
            if not wait_tcp_port('127.0.0.1', listen_port, timeout=3.0):
                return None, '启动失败'

            start = time.monotonic()
            r = subprocess.run(
                [
                    curl,
                    '--socks5-hostname',
                    f'127.0.0.1:{listen_port}',
                    '-fsS',
                    '-o',
                    os.devnull,
                    '-m',
                    str(int(timeout)),
                    PROBE_URL,
                ],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                text=True,
                timeout=timeout + 2,
            )
            cost = (time.monotonic() - start) * 1000
            if r.returncode == 0:
                return cost, None
            return None, '访问失败'
        except subprocess.TimeoutExpired:
            return None, '超时'
        finally:
            if proc and proc.poll() is None:
                proc.terminate()
                try:
                    proc.wait(timeout=2)
                except subprocess.TimeoutExpired:
                    proc.kill()
                    proc.wait(timeout=2)


def fmt_outbound_probe(value, error):
    if error:
        return '出站: ' + error
    if value is None:
        return '出站: 失败'
    return f'出站: {value:.0f}ms'


def verify_node_outbound(node):
    value, error = outbound_probe_latency(node)
    if error in ('缺 sing-box', '缺 curl'):
        return None, fmt_outbound_probe(value, error)
    if error or value is None:
        return False, fmt_outbound_probe(value, error)
    return True, fmt_outbound_probe(value, error)


def has_direct_outbound(data):
    outs = data.get('outbounds', [])
    if not isinstance(outs, list):
        return False

    return any(
        isinstance(o, dict) and o.get('tag') == 'direct'
        for o in outs
    )


def make_direct(data):
    if 'outbounds' not in data or not isinstance(data['outbounds'], list):
        data['outbounds'] = []

    if not has_direct_outbound(data):
        data['outbounds'].append({
            'type': 'direct',
            'tag': 'direct',
        })

    if 'route' not in data or not isinstance(data['route'], dict):
        data['route'] = {}

    data['route']['rules'] = []
    data['route']['final'] = 'direct'

    return data


def outbound_from_node_config(path):
    data = load_json(path)
    outs = data.get('outbounds', [])
    if not isinstance(outs, list):
        die('错误: 节点配置缺少 outbounds')

    by_tag = {
        o.get('tag'): o
        for o in outs
        if isinstance(o, dict) and isinstance(o.get('tag'), str)
    }

    route = data.get('route', {})
    if isinstance(route, dict):
        final = route.get('final')
        if isinstance(final, str) and final in by_tag:
            outbound = by_tag[final]
            if endpoint_from_outbound(outbound):
                return dict(outbound)

    for outbound in outs:
        if endpoint_from_outbound(outbound):
            return dict(outbound)

    die('错误: 节点配置中未找到可用的远程出口')


def remove_qie_outbounds(data):
    outs = data.get('outbounds', [])
    if not isinstance(outs, list):
        data['outbounds'] = []
        return

    data['outbounds'] = [
        o for o in outs
        if not (isinstance(o, dict) and o.get('tag') == QIE_OUT_TAG)
    ]


def ensure_direct_outbound(data):
    outs = data.get('outbounds')
    if not isinstance(outs, list):
        outs = []
        data['outbounds'] = outs

    for outbound in outs:
        if isinstance(outbound, dict) and outbound.get('tag') == QIE_DIRECT_TAG:
            return

    outs.append({'type': 'direct', 'tag': QIE_DIRECT_TAG})


def build_runtime_config(state, node=None):
    if not os.path.exists(CRUN):
        die('错误: 当前没有运行配置，无法切换')

    if not validate_json(CRUN):
        die('错误: 当前运行配置 JSON 不合法，放弃切换')

    data = load_json(CRUN)
    remove_qie_outbounds(data)
    ensure_direct_outbound(data)

    if state == 'DIRECT':
        final = QIE_DIRECT_TAG
    else:
        outbound = outbound_from_node_config(node['config'])
        outbound['tag'] = QIE_OUT_TAG
        data['outbounds'].append(outbound)
        final = QIE_OUT_TAG

    if 'route' not in data or not isinstance(data['route'], dict):
        data['route'] = {}

    data['route']['final'] = final
    return data


def ensure_direct_config():
    if os.path.exists(CDIRECT):
        if not validate_config(CDIRECT):
            die('错误: sb_direct.json 已存在但不合法，请手动修复')
        return

    if not os.path.exists(CRUN):
        die('错误: 当前没有运行配置，无法生成直连配置')

    if not validate_json(CRUN):
        die('错误: 当前运行配置 JSON 不合法，无法生成直连配置')

    data = make_direct(load_json(CRUN))
    save_json(CDIRECT, data)

    if not validate_config(CDIRECT):
        os.remove(CDIRECT)
        die('错误: 自动创建的直连配置不合法，已删除')

    print('已创建直连配置: ' + CDIRECT)


def restart_sb():
    if shutil.which('systemctl'):
        subprocess.run(
            ['systemctl', 'restart', 'sing-box'],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    elif shutil.which('rc-service'):
        subprocess.run(
            ['rc-service', 'sing-box', 'restart'],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    elif shutil.which('service'):
        subprocess.run(
            ['service', 'sing-box', 'restart'],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    else:
        print('错误: 未找到 systemctl、rc-service 或 service，无法重启 sing-box')
        return False

    for _ in range(6):
        time.sleep(0.5)
        if service_status() in ('active', 'started', 'running'):
            return True

    return False


def service_status():
    if shutil.which('systemctl'):
        r = subprocess.run(
            ['systemctl', 'is-active', 'sing-box'],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        return r.stdout.strip()

    if shutil.which('rc-service'):
        r = subprocess.run(
            ['rc-service', 'sing-box', 'status'],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        out = r.stdout.strip().lower()
        if 'started' in out or 'running' in out:
            return 'started'
        if 'stopped' in out:
            return 'stopped'
        return out or 'unknown'

    if shutil.which('service'):
        r = subprocess.run(
            ['service', 'sing-box', 'status'],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        out = r.stdout.strip().lower()
        if 'running' in out or 'started' in out:
            return 'running'
        if 'stopped' in out:
            return 'stopped'
        return out or 'unknown'

    return 'unknown'


def switch_to_path(state, label, src):
    if not os.path.exists(src):
        die('错误: 配置文件不存在 - ' + src)

    if not validate_config(src):
        die('错误: 目标配置不合法，放弃切换')

    rollback = None
    if os.path.exists(CRUN):
        if not validate_json(CRUN):
            die('错误: 当前运行配置 JSON 不合法，放弃切换')
        rollback = CRUN + '.rollback'
        shutil.copy2(CRUN, rollback)

    print('切换至 ' + label + ' ...', end=' ', flush=True)
    atomic_copy(src, CRUN)

    if restart_sb():
        save_state(state)
        print('OK')
        if rollback and os.path.exists(rollback):
            os.remove(rollback)
        return

    print('失败，回滚中...')

    if rollback and os.path.exists(rollback):
        atomic_copy(rollback, CRUN)
        os.remove(rollback)
        if restart_sb():
            print('已回滚到原配置')
        else:
            print('严重错误: 回滚后 sing-box 仍未启动')
            print('建议检查 sing-box 服务状态')
    else:
        try:
            os.remove(CRUN)
        except FileNotFoundError:
            pass
        print('没有可回滚的原配置，已移除失败配置')

    sys.exit(1)


def fallback_to_direct(rollback=None):
    print('出站检测失败，回退 Direct ...', end=' ', flush=True)
    try:
        data = build_runtime_config('DIRECT')
        tmp = CRUN + '.tmp'
        save_json(tmp, data)
        if not validate_config(tmp):
            raise RuntimeError('Direct 配置校验失败')
        os.replace(tmp, CRUN)
        if restart_sb():
            save_state('DIRECT')
            print('OK')
            if rollback and os.path.exists(rollback):
                os.remove(rollback)
            cleanup_qie_residue()
            return True
        print('失败')
    except Exception as e:
        print('失败 - ' + str(e))

    if rollback and os.path.exists(rollback):
        print('尝试恢复切换前配置 ...', end=' ', flush=True)
        atomic_copy(rollback, CRUN)
        os.remove(rollback)
        if restart_sb():
            print('OK')
        else:
            print('失败')

    cleanup_qie_residue()
    return False


def switch_runtime(state, label, node=None):
    rollback = None
    if os.path.exists(CRUN):
        rollback = CRUN + '.rollback'
        shutil.copy2(CRUN, rollback)

    data = build_runtime_config(state, node)
    tmp = CRUN + '.tmp'
    save_json(tmp, data)
    if not validate_config(tmp):
        try:
            os.remove(tmp)
        except FileNotFoundError:
            pass
        die('错误: 合并后的运行配置不合法，放弃切换')

    print('切换至 ' + label + ' ...', end=' ', flush=True)
    os.replace(tmp, CRUN)

    if restart_sb():
        print('OK')
        if state != 'DIRECT' and node:
            print('检测落地机出站 ...', end=' ', flush=True)
            ok, detail = verify_node_outbound(node)
            print(detail)
            if ok is False:
                if not fallback_to_direct(rollback):
                    sys.exit(1)
                return
            if ok is None:
                print('提示: 无法完成出站检测，保留当前切换。')

        save_state(state)
        if rollback and os.path.exists(rollback):
            os.remove(rollback)
        cleanup_qie_residue()
        return

    print('失败，回滚中...')
    if rollback and os.path.exists(rollback):
        atomic_copy(rollback, CRUN)
        os.remove(rollback)
        if restart_sb():
            print('已回滚到原配置')
        else:
            print('严重错误: 回滚后 sing-box 仍未启动')
            print('建议检查 sing-box 服务状态')
    else:
        print('没有可回滚的原配置，请手动检查 ' + CRUN)

    cleanup_qie_residue()
    sys.exit(1)


