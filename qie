    if load_index():
        return

    print('当前没有任何落地机配置。')
    print('请先在落地机 SSH 中执行 README 的导出命令，复制生成的数据块。')
    import_node()


def print_nodes():
    nodes = load_index()
    if not nodes:
        print('暂无落地机配置')
        return

    cur = get_state()
    for i, node in enumerate(nodes, 1):
        mark = '*' if cur == node['id'] else ' '
        ep = node.get('endpoint') or detect_endpoint_from_config(node['config'])
        print(f"{mark} {i}. {node['id']}  {node_label(node)}  {endpoint_text(ep)}  {test_protocol_text(node, ep)}  {node_latency_text(node)}")


def rename_node(key=None, new_name=None):
    nodes = load_index()
    if not nodes:
        print('暂无落地机配置')
        return

    if not key:
        print_nodes()
        try:
            key = input('输入要重命名的节点编号或名称: ').strip()
        except (EOFError, KeyboardInterrupt):
            print()
            die('已取消')

    node = None
    if key.isdigit():
        idx = int(key) - 1
        if 0 <= idx < len(nodes):
            node = nodes[idx]

    if not node:
        node = find_node(key)

    if not node:
        die('错误: 未找到节点 - ' + key)

    if not new_name:
        try:
            new_name = input('输入新的落地机名称: ').strip()
        except (EOFError, KeyboardInterrupt):
            print()
            die('已取消')

    if not new_name:
        die('错误: 名称不能为空')

    for item in nodes:
        if item['id'] == node['id']:
            item['name'] = new_name
            break

    save_index(nodes)
    print(f"已重命名: {node['id']} -> {new_name}")


def delete_node(key=None):
    nodes = load_index()
    if not nodes:
        print('暂无落地机配置')
        return

    if not key:
        print_nodes()
        try:
            key = input('输入要删除的节点编号或名称: ').strip()
        except (EOFError, KeyboardInterrupt):
            print()
            die('已取消')

    node = None
    if key.isdigit():
        idx = int(key) - 1
        if 0 <= idx < len(nodes):
            node = nodes[idx]

    if not node:
        node = find_node(key)

    if not node:
        die('错误: 未找到节点 - ' + key)

    try:
        answer = input(f"确认删除 {node_label(node)} ? [y/N]: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        die('已取消')

    if answer not in ('y', 'yes'):
        print('已取消删除。')
        return

    was_current = get_state() == node['id']
    nodes = [item for item in nodes if item['id'] != node['id']]
    save_index(nodes)

    config_path = node.get('config')
    if config_path:
        try:
            if os.path.isfile(config_path):
                os.remove(config_path)
        except OSError as e:
            print('提示: 删除配置文件失败 - ' + str(e))

    if was_current:
        try:
            os.remove(STATE)
        except FileNotFoundError:
            pass

    cleanup_qie_residue()
    print('已删除落地机: ' + node.get('name', node['id']))


