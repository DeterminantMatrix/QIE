#!/bin/sh
set -eu

NAME=""
CONFIG="/etc/hysteria/config.yaml"
PORT="8443"
SERVER=""
PASSWORD=""
SNI="qie.local"
NO_START=0
KEEP_DEPS=0

usage() {
  cat <<'EOF'
Usage:
  qie-export-node [options]

Options:
  -n, --name NAME          Node name shown in qie
  -c, --config FILE        Hysteria2 server config path, default: /etc/hysteria/config.yaml
  -p, --port PORT          Hysteria2 listen port, default: 8443
  --server HOST            Public host/IP used by the original machine
  --password PASSWORD      Hysteria2 password. Generated if omitted.
  --sni NAME               TLS server name, default: qie.local
  --no-start               Write config and export data without restarting Hysteria2
  --keep-deps              Keep helper packages installed by this script
  -h, --help               Show this help

Run this on the landing machine. It detects or installs Hysteria2, ensures a
server config exists, then prints a QIE_NODE block to paste into qie.
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

need_root() {
  [ "$(id -u)" -eq 0 ] || die "root is required to install or configure Hysteria2"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -n|--name)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      NAME="$2"
      shift 2
      ;;
    -c|--config)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      CONFIG="$2"
      shift 2
      ;;
    -p|--port)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      PORT="$2"
      shift 2
      ;;
    --server)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      SERVER="$2"
      shift 2
      ;;
    --password)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      PASSWORD="$2"
      shift 2
      ;;
    --sni)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      SNI="$2"
      shift 2
      ;;
    --no-start)
      NO_START=1
      shift
      ;;
    --keep-deps)
      KEEP_DEPS=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

detect_pm() {
  if have apk; then
    echo apk
  elif have apt-get; then
    echo apt
  else
    echo unknown
  fi
}

install_base_packages() {
  pm="$(detect_pm)"
  case "$pm" in
    apk)
      apk add --no-cache curl python3 openssl ca-certificates >/dev/null
      ;;
    apt)
      apt-get update >/dev/null
      DEBIAN_FRONTEND=noninteractive apt-get install -y curl python3 openssl ca-certificates >/dev/null
      ;;
    *)
      die "unsupported package manager. Install curl, python3 and openssl manually."
      ;;
  esac
}

remove_alpine_package_if_new() {
  pkg="$1"
  was_present="$2"

  if [ "$KEEP_DEPS" -eq 1 ] || [ "$was_present" -eq 1 ]; then
    return
  fi

  if have apk && apk info -e "$pkg" >/dev/null 2>&1; then
    apk del "$pkg" >/dev/null 2>&1 || true
  fi
}

arch_name() {
  case "$(uname -m)" in
    x86_64|amd64) echo amd64 ;;
    aarch64|arm64) echo arm64 ;;
    armv7l|armv7*) echo armv7 ;;
    armv6l|armv6*) echo arm ;;
    i386|i686) echo 386 ;;
    *) die "unsupported architecture: $(uname -m)" ;;
  esac
}

hysteria_bin() {
  if have hysteria; then
    command -v hysteria
    return
  fi
  if have hysteria2; then
    command -v hysteria2
    return
  fi
  if [ -x /usr/local/bin/hysteria ]; then
    echo /usr/local/bin/hysteria
    return
  fi
  return 1
}

install_hysteria_binary() {
  arch="$(arch_name)"
  url="$(python3 - "$arch" <<'PY'
import json
import sys
import urllib.request

arch = sys.argv[1]
with urllib.request.urlopen('https://api.github.com/repos/apernet/hysteria/releases/latest', timeout=20) as r:
    data = json.load(r)

target = f'hysteria-linux-{arch}'
for asset in data.get('assets', []):
    if asset.get('name') == target:
        print(asset['browser_download_url'])
        break
else:
    raise SystemExit(f'no Hysteria2 linux asset found for {arch}')
PY
)"
  curl -fsSL "$url" -o /usr/local/bin/hysteria
  chmod 755 /usr/local/bin/hysteria
}

ensure_dependencies() {
  HAD_CURL=0
  HAD_PYTHON3=0
  HAD_OPENSSL=0
  have curl && HAD_CURL=1
  have python3 && HAD_PYTHON3=1
  have openssl && HAD_OPENSSL=1

  missing=0
  have curl || missing=1
  have python3 || missing=1
  have openssl || missing=1

  if [ "$missing" -eq 1 ]; then
    need_root
    echo "Installing base packages..." >&2
    install_base_packages
  fi

}

ensure_hysteria() {
  if ! hysteria_bin >/dev/null 2>&1; then
    need_root
    echo "Installing Hysteria2..." >&2
    install_hysteria_binary
  fi
}

cleanup_after_export() {
  rm -f /etc/s-box/certs/qie-hy2.crt /etc/s-box/certs/qie-hy2.key 2>/dev/null || true
  rmdir /etc/s-box/certs /etc/s-box 2>/dev/null || true

  if [ "$(detect_pm)" = "apk" ]; then
    remove_alpine_package_if_new curl "$HAD_CURL"
    remove_alpine_package_if_new python3 "$HAD_PYTHON3"
    remove_alpine_package_if_new openssl "$HAD_OPENSSL"
  fi
}

detect_server() {
  if [ -n "$SERVER" ]; then
    echo "$SERVER"
    return
  fi

  for url in \
    https://api.ipify.org \
    https://ifconfig.me/ip \
    https://icanhazip.com
  do
    ip="$(curl -4fsSL --max-time 6 "$url" 2>/dev/null | tr -d ' \r\n' || true)"
    if [ -n "$ip" ]; then
      echo "$ip"
      return
    fi
  done

  host="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
  [ -n "$host" ] || die "cannot detect public IP. Use --server HOST."
  echo "$host"
}

detect_existing_config() {
  if [ -f "$CONFIG" ]; then
    echo "$CONFIG"
    return
  fi

  for candidate in \
    /etc/hysteria/config.yaml \
    /etc/hysteria/config.yml \
    /etc/hysteria/*.yaml \
    /etc/hysteria/*.yml
  do
    if [ -f "$candidate" ]; then
      echo "$candidate"
      return
    fi
  done

  echo "$CONFIG"
}

EXPORT_TMP=""

try_export_existing() {
  EXPORT_TMP="$(mktemp)"
  python3 - "$SERVER" "$SNI" "$NAME" "$EXPORT_TMP" <<'PY'
import base64
import json
import os
import re
import socket
import sys
import time

server, sni, name, export_path = sys.argv[1:]

def emit(config_path, port, password):
    client_config = {
        'log': {'level': 'info'},
        'inbounds': [
            {
                'type': 'mixed',
                'tag': 'mixed-in',
                'listen': '127.0.0.1',
                'listen_port': 2080,
            }
        ],
        'outbounds': [
            {
                'type': 'hysteria2',
                'tag': 'proxy',
                'server': server,
                'server_port': int(port),
                'password': password,
                'tls': {
                    'enabled': True,
                    'server_name': sni,
                    'insecure': True,
                },
            },
            {'type': 'direct', 'tag': 'direct'},
        ],
        'route': {'rules': [], 'final': 'proxy'},
    }

    payload = {
        'format': 'qie-node',
        'version': 1,
        'name': name,
        'source_host': socket.gethostname(),
        'source_config': config_path,
        'exported_at': time.strftime('%Y-%m-%dT%H:%M:%S%z'),
        'server': server,
        'server_port': int(port),
        'protocol': 'hysteria2',
        'config': client_config,
    }
    raw = json.dumps(payload, ensure_ascii=False, separators=(',', ':')).encode('utf-8')
    encoded = base64.b64encode(raw).decode('ascii')
    with open(export_path, 'w', encoding='utf-8', newline='\n') as f:
        f.write('QIE_NODE_BEGIN\n')
        for i in range(0, len(encoded), 76):
            f.write(encoded[i:i + 76] + '\n')
        f.write('QIE_NODE_END\n')

def read_text(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        return f.read()

def find_scalar(text, key_name):
    m = re.search(rf'(?m)^\s*{re.escape(key_name)}\s*:\s*["\']?([^"\'\n#]+)', text)
    return m.group(1).strip() if m else None

def parse_hysteria_config(path):
    text = read_text(path)
    if not text.strip():
        return None
    password = find_scalar(text, 'password')
    listen = find_scalar(text, 'listen')
    if not password or not listen:
        return None
    m = re.search(r':(\d+)$', listen)
    if not m:
        return None
    return int(m.group(1)), password

def split_host_port(server_value):
    if not isinstance(server_value, str):
        return None, None
    s = server_value.strip()
    if s.startswith('[') and ']' in s:
        rest = s[s.index(']') + 1:]
        if rest.startswith(':'):
            try:
                return s[1:s.index(']')], int(rest[1:])
            except ValueError:
                return s[1:s.index(']')], None
    if ':' in s and s.count(':') == 1:
        host, port = s.rsplit(':', 1)
        try:
            return host, int(port)
        except ValueError:
            return s, None
    return s, None

def parse_singbox_config(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        data = json.load(f)
    for inbound in data.get('inbounds', []):
        if not isinstance(inbound, dict):
            continue
        if inbound.get('type') not in ('hysteria2', 'hy2'):
            continue

        port = inbound.get('listen_port')
        if port is None:
            _, port = split_host_port(inbound.get('listen'))
        try:
            port = int(port)
        except Exception:
            port = None

        password = inbound.get('password')
        users = inbound.get('users')
        if not password and isinstance(users, list):
            for user in users:
                if isinstance(user, dict) and user.get('password'):
                    password = user['password']
                    break

        if port and password:
            return port, password
    return None

hysteria_paths = [
    '/etc/hysteria/config.yaml',
    '/etc/hysteria/config.yml',
]
for base in ('/etc/hysteria',):
    if os.path.isdir(base):
        for name2 in sorted(os.listdir(base)):
            if name2.endswith(('.yaml', '.yml')):
                hysteria_paths.append(os.path.join(base, name2))

seen = set()
for path in hysteria_paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    parsed = parse_hysteria_config(path)
    if parsed:
        port, password = parsed
        print(f'Detected existing Hysteria2 config: {path}', file=sys.stderr)
        emit(path, port, password)
        raise SystemExit(0)

singbox_paths = [
    '/etc/s-box/sb.json',
    '/etc/sing-box/config.json',
    '/usr/local/etc/sing-box/config.json',
]
for base in ('/etc/s-box', '/etc/sing-box'):
    if os.path.isdir(base):
        for name2 in sorted(os.listdir(base)):
            if name2.endswith('.json'):
                singbox_paths.append(os.path.join(base, name2))

seen = set()
for path in singbox_paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    try:
        parsed = parse_singbox_config(path)
    except Exception as e:
        print(f'Skip unreadable sing-box config {path}: {e}', file=sys.stderr)
        continue
    if parsed:
        port, password = parsed
        print(f'Detected existing sing-box Hysteria2 inbound: {path}', file=sys.stderr)
        emit(path, port, password)
        raise SystemExit(0)

raise SystemExit(2)
PY
}

ensure_service() {
  config="$1"
  bin="$2"

  if [ "$NO_START" -eq 1 ]; then
    echo "Skipping Hysteria2 restart because --no-start is set." >&2
    return
  fi

  if have systemctl; then
    if ! systemctl cat hysteria-server.service >/dev/null 2>&1; then
      cat >/etc/systemd/system/hysteria-server.service <<EOF
[Unit]
Description=Hysteria2 server for QIE
After=network.target

[Service]
ExecStart=$bin server -c $config
Restart=on-failure
RestartSec=10
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
      systemctl daemon-reload
    fi
    systemctl enable hysteria-server >/dev/null 2>&1 || true
    systemctl restart hysteria-server
    return
  fi

  if have rc-service; then
    if [ ! -x /etc/init.d/hysteria-server ]; then
      cat >/etc/init.d/hysteria-server <<EOF
#!/sbin/openrc-run
name="hysteria-server"
description="Hysteria2 server for QIE"
command="$bin"
command_args="server -c $config"
command_background="yes"
pidfile="/run/hysteria-server.pid"

depend() {
  need net
}
EOF
      chmod +x /etc/init.d/hysteria-server
    fi
    rc-update add hysteria-server default >/dev/null 2>&1 || true
    rc-service hysteria-server restart
    return
  fi

  if have service; then
    service hysteria-server restart
    return
  fi

  die "cannot restart Hysteria2: no systemctl, rc-service or service found"
}

if [ -z "$NAME" ]; then
  NAME="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo node)"
fi

case "$PORT" in
  *[!0-9]*|'') die "invalid port: $PORT" ;;
esac

ensure_dependencies
SERVER="$(detect_server)"

if try_export_existing; then
  cat "$EXPORT_TMP"
  rm -f "$EXPORT_TMP"
  cleanup_after_export
  exit 0
fi

rm -f "$EXPORT_TMP"

ensure_hysteria
CONFIG="$(detect_existing_config)"
HYSTERIA="$(hysteria_bin)"

need_root
mkdir -p "$(dirname "$CONFIG")" /etc/hysteria/certs

CERT="/etc/hysteria/certs/qie-hy2.crt"
KEY="/etc/hysteria/certs/qie-hy2.key"

if [ ! -f "$CERT" ] || [ ! -f "$KEY" ]; then
  echo "Generating self-signed TLS certificate..." >&2
  openssl req -x509 -newkey rsa:2048 -keyout "$KEY" -out "$CERT" -days 3650 -nodes -subj "/CN=$SNI" >/dev/null 2>&1
  chmod 600 "$KEY"
fi

if [ -z "$PASSWORD" ]; then
  PASSWORD="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(24))
PY
)"
fi

echo "Ensuring Hysteria2 server config in: $CONFIG" >&2

trap 'rm -f "$EXPORT_TMP"' EXIT HUP INT TERM
EXPORT_TMP="$(mktemp)"

python3 - "$CONFIG" "$PORT" "$PASSWORD" "$CERT" "$KEY" "$SERVER" "$SNI" "$NAME" "$EXPORT_TMP" <<'PY'
import base64
import json
import os
import re
import shutil
import socket
import sys
import time

config_path, port, password, cert, key, server, sni, name, export_path = sys.argv[1:]
port = int(port)

def read_text(path):
    if not os.path.exists(path):
        return ''
    with open(path, 'r', encoding='utf-8-sig') as f:
        return f.read()

def write_text(path, text):
    if os.path.exists(path):
        backup = path + '.qie.bak'
        shutil.copy2(path, backup)
        print(f'Backup: {backup}', file=sys.stderr)
    tmp = path + '.tmp'
    with open(tmp, 'w', encoding='utf-8', newline='\n') as f:
        f.write(text)
    os.replace(tmp, path)

def find_scalar(text, key_name):
    m = re.search(rf'(?m)^\s*{re.escape(key_name)}\s*:\s*["\']?([^"\'\n#]+)', text)
    return m.group(1).strip() if m else None

existing = read_text(config_path)

if existing.strip():
    listen = find_scalar(existing, 'listen')
    auth = find_scalar(existing, 'password')
    if auth:
        password = auth
    if listen:
        m = re.search(r':(\d+)$', listen)
        if m:
            port = int(m.group(1))
    print('Detected existing Hysteria2 config.', file=sys.stderr)
else:
    text = f'''listen: :{port}

tls:
  cert: {cert}
  key: {key}

auth:
  type: password
  password: {password}

masquerade:
  type: proxy
  proxy:
    url: https://www.bing.com/
    rewriteHost: true
'''
    write_text(config_path, text)
    print('Created Hysteria2 config.', file=sys.stderr)

client_config = {
    'log': {
        'level': 'info',
    },
    'inbounds': [
        {
            'type': 'mixed',
            'tag': 'mixed-in',
            'listen': '127.0.0.1',
            'listen_port': 2080,
        }
    ],
    'outbounds': [
        {
            'type': 'hysteria2',
            'tag': 'proxy',
            'server': server,
            'server_port': port,
            'password': password,
            'tls': {
                'enabled': True,
                'server_name': sni,
                'insecure': True,
            },
        },
        {
            'type': 'direct',
            'tag': 'direct',
        },
    ],
    'route': {
        'rules': [],
        'final': 'proxy',
    },
}

payload = {
    'format': 'qie-node',
    'version': 1,
    'name': name,
    'source_host': socket.gethostname(),
    'source_config': config_path,
    'exported_at': time.strftime('%Y-%m-%dT%H:%M:%S%z'),
    'server': server,
    'server_port': port,
    'protocol': 'hysteria2',
    'config': client_config,
}

raw = json.dumps(payload, ensure_ascii=False, separators=(',', ':')).encode('utf-8')
encoded = base64.b64encode(raw).decode('ascii')

with open(export_path, 'w', encoding='utf-8', newline='\n') as f:
    f.write('QIE_NODE_BEGIN\n')
    for i in range(0, len(encoded), 76):
        f.write(encoded[i:i + 76] + '\n')
    f.write('QIE_NODE_END\n')
PY

ensure_service "$CONFIG" "$HYSTERIA"
cat "$EXPORT_TMP"
cleanup_after_export
