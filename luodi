bbr_current() {
  sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null \
    || cat /proc/sys/net/ipv4/tcp_congestion_control 2>/dev/null \
    || echo unknown
}

bbr_available() {
  sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null \
    || cat /proc/sys/net/ipv4/tcp_available_congestion_control 2>/dev/null \
    || echo unknown
}

install_bbr() {
  need_root
  if ! have bash; then
    echo "正在为 BBR 工具安装 bash..." >&2
    install_packages bash
  fi
  have curl || install_packages curl

  echo "正在运行 BBR 工具..." >&2
  if [ -r /dev/tty ]; then
    bash -c 'set -e; bash <(curl -fsSL "https://raw.githubusercontent.com/Eric86777/vps-tcp-tune/main/install-alias.sh?$(date +%s)"); bash <(curl -fsSL "https://raw.githubusercontent.com/Eric86777/vps-tcp-tune/main/net-tcp-tune.sh?$(date +%s)")' </dev/tty
  else
    bash -c 'set -e; bash <(curl -fsSL "https://raw.githubusercontent.com/Eric86777/vps-tcp-tune/main/install-alias.sh?$(date +%s)"); bash <(curl -fsSL "https://raw.githubusercontent.com/Eric86777/vps-tcp-tune/main/net-tcp-tune.sh?$(date +%s)")'
  fi
}

emit_export() {
  source_path="$1"
  port="$2"
  password="$3"
  sni="$4"
  out="$5"
  [ -n "$sni" ] || sni="$SNI"
  python3 - "$SERVER" "$sni" "$NAME" "$source_path" "$port" "$password" "$out" <<'PY'
import base64
import json
import socket
import sys
import time

