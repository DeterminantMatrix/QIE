print_detect_result() {
  hy2_file="$1"
  ss_file="$2"
  echo "========================" >&2
  echo " 落地机协议检测" >&2
  echo "========================" >&2
  if [ "$HY2_EXISTS" -eq 1 ]; then
    echo "Hysteria2/UDP: 已检测到 $(json_field "$hy2_file" path) :$(json_field "$hy2_file" port)" >&2
  else
    echo "Hysteria2/UDP: 未检测到" >&2
  fi
  if [ "$SS_EXISTS" -eq 1 ]; then
    echo "Shadowsocks/TCP: 已检测到 $(json_field "$ss_file" path) :$(json_field "$ss_file" port)" >&2
