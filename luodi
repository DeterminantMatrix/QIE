PY
}

detect_existing_config() {
  if [ -f "$CONFIG" ]; then
    echo "$CONFIG"
    return
  fi
  for candidate in /etc/hysteria/config.yaml /etc/hysteria/config.yml /etc/hysteria/*.yaml /etc/hysteria/*.yml; do
    [ -f "$candidate" ] && {
      echo "$candidate"
      return
    }
  done
  echo "$CONFIG"
}

ensure_service() {
  config="$1"
  bin="$2"

  if [ "$NO_START" -eq 1 ]; then
    echo "已设置 --no-start，跳过 Hysteria2 重启。" >&2
    return
  fi

  if have systemctl; then
    if ! systemctl cat hysteria-server.service >/dev/null 2>&1; then
      cat >/etc/systemd/system/hysteria-server.service <<EOF
[Unit]
Description=Hysteria2 server for QIE
After=network.target

[Service]
ExecStart=$bin server -c $config
Restart=on-failure
RestartSec=10
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
      systemctl daemon-reload
    fi
    systemctl enable hysteria-server >/dev/null 2>&1 || true
    systemctl restart hysteria-server
    return
  fi

  if have rc-service; then
    if [ ! -x /etc/init.d/hysteria-server ]; then
      cat >/etc/init.d/hysteria-server <<EOF
#!/sbin/openrc-run
name="hysteria-server"
description="Hysteria2 server for QIE"
command="$bin"
command_args="server -c $config"
command_background="yes"
pidfile="/run/hysteria-server.pid"

depend() {
  need net
}
EOF
      chmod +x /etc/init.d/hysteria-server
    fi
    rc-update add hysteria-server default >/dev/null 2>&1 || true
    rc-service hysteria-server restart
    return
  fi

  if have service; then
    service hysteria-server restart
    return
  fi

  die "无法重启 Hysteria2：未找到 systemctl、rc-service 或 service"
}

ensure_singbox_service() {
  config="$1"
  bin="$2"

  if [ "$NO_START" -eq 1 ]; then
    echo "已设置 --no-start，跳过 Shadowsocks TCP 服务启动。" >&2
    return
  fi

  if have systemctl; then
    cat >/etc/systemd/system/qie-shadowsocks.service <<EOF
[Unit]
Description=QIE Shadowsocks TCP landing server
After=network.target

[Service]
ExecStart=$bin run -c $config
Restart=on-failure
RestartSec=10
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable qie-shadowsocks >/dev/null 2>&1 || true
    systemctl restart qie-shadowsocks
    return
  fi

  if have rc-service; then
    cat >/etc/init.d/qie-shadowsocks <<EOF
#!/sbin/openrc-run
name="qie-shadowsocks"
description="QIE Shadowsocks TCP landing server"
command="$bin"
command_args="run -c $config"
command_background="yes"
pidfile="/run/qie-shadowsocks.pid"

depend() {
  need net
}
EOF
    chmod +x /etc/init.d/qie-shadowsocks
    rc-update add qie-shadowsocks default >/dev/null 2>&1 || true
    rc-service qie-shadowsocks restart
    return
  fi

  if have nohup; then
    nohup "$bin" run -c "$config" >/var/log/qie-shadowsocks.log 2>&1 &
    echo "未找到服务管理器，已用后台进程启动 Shadowsocks TCP。" >&2
    return
  fi

  die "无法启动 Shadowsocks TCP：未找到 systemctl、rc-service 或可用的后台启动方式"
}

restart_hysteria_service() {
  if [ "$NO_START" -eq 1 ]; then
    echo "已设置 --no-start，跳过 Hysteria2 重启。" >&2
    return
  fi

  if have systemctl; then
    for svc in hysteria-server hysteria; do
      if systemctl cat "$svc.service" >/dev/null 2>&1; then
        systemctl restart "$svc.service"
        return
      fi
    done
  fi

  if have rc-service; then
    for svc in hysteria-server hysteria; do
      if [ -x "/etc/init.d/$svc" ]; then
        rc-service "$svc" restart
        return
      fi
    done
  fi

  if have service; then
    for svc in hysteria-server hysteria; do
      if service "$svc" status >/dev/null 2>&1; then
        service "$svc" restart
        return
      fi
    done
  fi

  warn "未找到可重启的 Hysteria2 服务，请手动重启。"
}

update_hysteria_port() {
  config="$1"
  new_port="$2"
  validate_port "$new_port" "监听端口"
  need_root

  python3 - "$config" "$new_port" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
port = sys.argv[2]
text = path.read_text(encoding='utf-8-sig')
pattern = re.compile(r'(?m)^(\s*listen\s*:\s*)([^#\n]*?)(\s*#.*)?$')

def repl(match):
    return f'{match.group(1)}:{port}{match.group(3) or ""}'

new_text, count = pattern.subn(repl, text, count=1)
if count == 0:
    new_text = f'listen: :{port}\n' + text
path.write_text(new_text, encoding='utf-8', newline='\n')
PY
  restart_hysteria_service
}
create_shadowsocks_config() {
 if ! singbox_bin >/dev/null 2>&1; then
  install_singbox_binary
 fi
 SINGBOX="$(singbox_bin)"
 ask_ss_port
 need_root
 mkdir -p "$(dirname "$SS_CONFIG")"
 if [ -z "$PASSWORD" ]; then
  case "$SS_METHOD" in
   2022-blake3-aes-128-gcm) key_len=16 ;;
   2022-blake3-aes-256-gcm|2022-blake3-chacha20-poly1305) key_len=32 ;;
   *) key_len=0 ;;
  esac
  if [ "$key_len" -gt 0 ]; then
   PASSWORD="$($SINGBOX generate rand --base64 "$key_len" 2>/dev/null || openssl rand -base64 "$key_len")"
  else
   PASSWORD="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(24))
PY
)"
  fi
 fi
 python3 - "$SS_CONFIG" "$SS_META" "$SS_PORT" "$SS_METHOD" "$PASSWORD" <<'PY'
import json
import sys

config_path, meta_path, port, method, password = sys.argv[1:]
port = int(port)
config = {
    'log': {'level': 'info'},
    'inbounds': [
        {
            'type': 'shadowsocks',
            'tag': 'shadowsocks-in',
            'listen': '0.0.0.0',
            'listen_port': port,
            'network': 'tcp',
            'method': method,
            'password': password,
        }
    ],
    'outbounds': [
        {'type': 'direct', 'tag': 'direct'},
    ],
    'route': {'final': 'direct'},
}
meta = {
    'kind': 'shadowsocks',
    'path': config_path,
    'port': port,
    'method': method,
    'password': password,
}
with open(config_path, 'w', encoding='utf-8', newline='\n') as f:
    json.dump(config, f, ensure_ascii=False, indent=2)
    f.write('\n')
with open(meta_path, 'w', encoding='utf-8', newline='\n') as f:
    json.dump(meta, f, ensure_ascii=False, indent=2)
    f.write('\n')
PY
 "$SINGBOX" check -c "$SS_CONFIG" >/dev/null
 ensure_singbox_service "$SS_CONFIG" "$SINGBOX"
}
choose_install_protocol() {
 if [ -n "$INSTALL_PROTOCOL" ]; then
  echo "$INSTALL_PROTOCOL"
  return
 fi
 if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
  echo hy2
  return
 fi
 while :; do
  echo "未检测到可用协议服务，请选择安装模式：" >/dev/tty
  echo " 1) Hysteria2 / UDP" >/dev/tty
  echo " 2) Shadowsocks TCP" >/dev/tty
  printf "请选择 [1/2，默认 1]: " >/dev/tty
  IFS= read -r answer </dev/tty || answer=""
  case "$answer" in
   1|'') echo hy2; return ;;
   2) echo ss; return ;;
   *) echo "请输入 1 或 2。" >/dev/tty ;;
  esac
 done
}
choose_export_protocol() {
 if [ "$HY2_EXISTS" -eq 1 ] && [ "$SS_EXISTS" -eq 1 ]; then
  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
   echo hy2
   return
  fi
  while :; do
   echo "检测到多个可导出的协议，请选择导出：" >/dev/tty
   echo " 1) Hysteria2 / UDP" >/dev/tty
   echo " 2) Shadowsocks TCP" >/dev/tty
   printf "请选择 [1/2，默认 1]: " >/dev/tty
   IFS= read -r answer </dev/tty || answer=""
   case "$answer" in
    1|'') echo hy2; return ;;
    2) echo ss; return ;;
    *) echo "请输入 1 或 2。" >/dev/tty ;;
   esac
  done
 elif [ "$HY2_EXISTS" -eq 1 ]; then
  echo hy2
 elif [ "$SS_EXISTS" -eq 1 ]; then
  echo ss
 else
  echo ""
 fi
}

create_hysteria_config() {
  ensure_hysteria_missing=0
  if ! hysteria_bin >/dev/null 2>&1; then
    install_hysteria_binary
    ensure_hysteria_missing=1
  fi
  HYSTERIA="$(hysteria_bin)"
  CONFIG="$(detect_existing_config)"

  need_root
  mkdir -p "$(dirname "$CONFIG")" /etc/hysteria/certs

  cert="/etc/hysteria/certs/qie-hy2.crt"
  key="/etc/hysteria/certs/qie-hy2.key"

  if [ ! -f "$cert" ] || [ ! -f "$key" ]; then
    echo "正在生成自签 TLS 证书..." >&2
    openssl req -x509 -newkey rsa:2048 -keyout "$key" -out "$cert" -days 3650 -nodes -subj "/CN=$SNI" >/dev/null 2>&1
    chmod 600 "$key"
  fi

  if [ -z "$PASSWORD" ]; then
    PASSWORD="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(24))
PY
)"
  fi

  if [ ! -s "$CONFIG" ]; then
    cat >"$CONFIG" <<EOF
listen: :$PORT

tls:
  cert: $cert
  key: $key

auth:
  type: password
  password: $PASSWORD

masquerade:
  type: proxy
  proxy:
    url: https://www.bing.com/
    rewriteHost: true
EOF
  fi

  ensure_service "$CONFIG" "$HYSTERIA"
}

ask_node_name

validate_port "$PORT" "监听端口"

ensure_base_dependencies
SERVER="$(detect_server)"

DETECT_TMP="$(mktemp)"
VLESS_TMP="$(mktemp)"
EXPORT_TMP="$(mktemp)"
trap 'rm -f "$DETECT_TMP" "$VLESS_TMP" "$EXPORT_TMP"' EXIT HUP INT TERM

if detect_existing_hy2 "$DETECT_TMP"; then
  HY2_EXISTS=1
else
  HY2_EXISTS=0
fi

if detect_existing_shadowsocks "$VLESS_TMP"; then
  SS_EXISTS=1
else
  SS_EXISTS=0
fi

if singbox_exists; then
  SINGBOX_EXISTS=1
else
  SINGBOX_EXISTS=0
fi

BBR_CURRENT="$(bbr_current)"
BBR_AVAILABLE="$(bbr_available)"

echo "========================"
echo " QIE 落地机检测"
echo "========================"
if [ "$HY2_EXISTS" -eq 1 ]; then
  echo "hy2: 有 ($(json_field "$DETECT_TMP" kind), $(json_field "$DETECT_TMP" path), 端口 $(json_field "$DETECT_TMP" port))"
  DETECTED_SNI="$(json_field "$DETECT_TMP" sni)"
  if [ -n "$DETECTED_SNI" ]; then
    echo "SNI: $DETECTED_SNI"
  else
    echo "SNI: $SNI (未从配置识别，使用默认/参数)"
  fi
else
  echo "hy2: 无"
fi
if [ "$SS_EXISTS" -eq 1 ]; then
  echo "Shadowsocks TCP: 有 ($(json_field "$VLESS_TMP" path), TCP 端口 $(json_field "$VLESS_TMP" port), 握手域名 $(json_field "$VLESS_TMP" server_name))"
else
  echo "Shadowsocks TCP: 无"
fi
if [ "$SINGBOX_EXISTS" -eq 1 ]; then
  echo "sing-box: 有"
else
  echo "sing-box: 无"
fi
echo "BBR: 当前=$BBR_CURRENT 可用=$BBR_AVAILABLE"
echo "连接地址: $SERVER"
echo "========================"

if [ "$HY2_EXISTS" -eq 1 ] && [ "$(json_field "$DETECT_TMP" kind)" = "hysteria" ]; then
  if ask_yes_no "是否修改 hy2 监听端口" "n" 0; then
    CURRENT_PORT="$(json_field "$DETECT_TMP" port)"
    PORT="$(ask_port_value "请输入新的 Hysteria2 监听 UDP 端口" "$CURRENT_PORT")"
    update_hysteria_port "$(json_field "$DETECT_TMP" path)" "$PORT"
    if detect_existing_hy2 "$DETECT_TMP"; then
      HY2_EXISTS=1
      echo "hy2 端口已更新为: $(json_field "$DETECT_TMP" port)"
    else
      HY2_EXISTS=0
      warn "修改端口后未检测到 hy2，请检查配置和服务状态。"
    fi
  fi
elif [ "$HY2_EXISTS" -eq 1 ] && [ "$(json_field "$DETECT_TMP" kind)" = "sing-box" ]; then
  echo "提示: 检测到 sing-box 内置 hy2，luodi 不自动修改 sing-box 端口。"
fi

if [ "$BBR_CURRENT" != "bbr" ]; then
  if ask_yes_no "现在安装/启用 BBR" "n" 0; then
    if ! install_bbr; then
      warn "BBR 工具失败，或被容器/宿主机限制；继续执行后续步骤。"
    fi
    BBR_CURRENT="$(bbr_current)"
    echo "BBR 执行后: 当前=$BBR_CURRENT"
  fi
fi

if [ "$HY2_EXISTS" -eq 0 ]; then
  if [ "$SS_EXISTS" -eq 0 ]; then
    SELECTED_PROTOCOL="$(choose_install_protocol)"
    case "$SELECTED_PROTOCOL" in
      hy2)
        if ask_yes_no "现在安装 Hysteria2 / UDP" "n"; then
          ask_hysteria_port
          create_hysteria_config
          if detect_existing_hy2 "$DETECT_TMP"; then
            HY2_EXISTS=1
          fi
        fi
        ;;
      ss)
        if ask_yes_no "现在安装 Shadowsocks TCP / TCP" "n"; then
          create_shadowsocks_config
          if detect_existing_shadowsocks "$VLESS_TMP"; then
            SS_EXISTS=1
          fi
        fi
        ;;
    esac
  fi
fi

EXPORT_PROTOCOL="$(choose_export_protocol)"
if [ -z "$EXPORT_PROTOCOL" ]; then
  warn "没有可用协议服务，无法导出。"
  cleanup_after_export
  exit 0
fi

if ask_yes_no "现在导出 QIE 导入数据" "y"; then
  case "$EXPORT_PROTOCOL" in
    hy2)
      emit_export \
        "$(json_field "$DETECT_TMP" path)" \
        "$(json_field "$DETECT_TMP" port)" \
        "$(json_field "$DETECT_TMP" password)" \
        "$(json_field "$DETECT_TMP" sni)" \
        "$EXPORT_TMP"
      ;;
    ss)
      emit_shadowsocks_export \
        "$(json_field "$VLESS_TMP" path)" \
        "$(json_field "$VLESS_TMP" port)" \
        "$(json_field "$VLESS_TMP" uuid)" \
        "$(json_field "$VLESS_TMP" public_key)" \
        "$(json_field "$VLESS_TMP" short_id)" \
        "$(json_field "$VLESS_TMP" server_name)" \
        "$EXPORT_TMP"
      ;;
    *)
      die "未知导出协议: $EXPORT_PROTOCOL"
      ;;
  esac
  cat "$EXPORT_TMP"
else
  echo "已跳过导出。"
fi

cleanup_after_export
