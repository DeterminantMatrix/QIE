main() {
  ensure_base_dependencies
  ask_node_name

  hy2_file="$(mktemp)"
  ss_file="$(mktemp)"
  HY2_EXISTS=0
  SS_EXISTS=0
  if detect_existing_hy2 "$hy2_file" >/dev/null 2>&1; then HY2_EXISTS=1; fi
  if detect_existing_shadowsocks "$ss_file" >/dev/null 2>&1; then SS_EXISTS=1; fi
  print_detect_result "$hy2_file" "$ss_file"

  if [ "$HY2_EXISTS" -eq 0 ] && [ "$SS_EXISTS" -eq 0 ]; then
    protocol="$(choose_install_protocol)"
    case "$protocol" in
      hy2) create_hysteria_config ;;
      ss) create_shadowsocks_config ;;
      *) die "内部错误：未知协议 $protocol" ;;
    esac
    rm -f "$hy2_file" "$ss_file"
    hy2_file="$(mktemp)"
    ss_file="$(mktemp)"
    HY2_EXISTS=0
    SS_EXISTS=0
    if detect_existing_hy2 "$hy2_file" >/dev/null 2>&1; then HY2_EXISTS=1; fi
    if detect_existing_shadowsocks "$ss_file" >/dev/null 2>&1; then SS_EXISTS=1; fi
    print_detect_result "$hy2_file" "$ss_file"
  fi

  export_protocol="$(choose_export_protocol)"
  case "$export_protocol" in
    hy2)
      if [ "$HY2_EXISTS" -ne 1 ]; then die "没有可导出的 Hysteria2 配置"; fi
      export_hysteria "$hy2_file"
      ;;
    ss)
      if [ "$SS_EXISTS" -ne 1 ]; then die "没有可导出的 Shadowsocks 配置"; fi
      export_shadowsocks "$ss_file"
      ;;
    *) die "没有可导出的协议配置" ;;
  esac

  rm -f "$hy2_file" "$ss_file"
  cleanup_after_export
}

main "$@"
