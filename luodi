#!/bin/sh
set -eu

NAME=""
CONFIG="/etc/hysteria/config.yaml"
PORT="8443"
PORT_SET=0
SS_PORT="8388"
SS_PORT_SET=0
SERVER=""
PASSWORD=""
SNI="qie.local"
SS_METHOD="2022-blake3-aes-128-gcm"
INSTALL_PROTOCOL=""
NO_START=0
KEEP_DEPS=0
YES=0
SS_CONFIG="/etc/sing-box/qie-shadowsocks.json"
SS_META="/etc/sing-box/qie-shadowsocks.meta.json"

usage() {
  cat <<'EOF'
用法:
  luodi [选项]

选项:
  -n, --name NAME          qie 菜单中显示的节点名称
  -c, --config FILE        Hysteria2 服务端配置路径，默认 /etc/hysteria/config.yaml
  -p, --port PORT          Hysteria2 监听端口，默认 8443
  --vless-port PORT        Shadowsocks TCP TCP 监听端口，默认 443
  --reality-server NAME    Reality 握手伪装域名，默认 www.microsoft.com
  --protocol MODE          没有协议服务时安装的模式：hy2 或 ss
  --server HOST            原机器连接落地机时使用的公网地址/IP
  --password PASSWORD      Hysteria2 密码；不填则自动生成
  --sni NAME               TLS SNI，默认 qie.local
  --no-start               写入配置和导出数据，但不重启 Hysteria2
  --keep-deps              保留本脚本安装的辅助依赖
  -y, --yes                非交互：自动安装缺失协议并导出
  -h, --help               显示帮助

在落地机上运行。本脚本会先显示检测结果；如果没有可用协议服务，
会让你选择 Hysteria2/UDP 或 Shadowsocks TCP。
EOF
}

die() {
  echo "错误: $*" >&2
  exit 1
}

warn() {
  echo "警告: $*" >&2
}

have() {
  command -v "$1" >/dev/null 2>&1
}

need_root() {
  [ "$(id -u)" -eq 0 ] || die "该操作需要 root 权限"
}

ask_yes_no() {
  prompt="$1"
  default="${2:-n}"
  auto="${3:-1}"

  if [ "$YES" -eq 1 ] && [ "$auto" -eq 1 ]; then
    echo "$prompt: 是（自动确认）" >&2
    return 0
  fi

  if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    [ "$default" = "y" ]
    return
  fi

  if [ "$default" = "y" ]; then
    printf "%s [Y/n]: " "$prompt" >/dev/tty
  else
    printf "%s [y/N]: " "$prompt" >/dev/tty
  fi

  IFS= read -r answer </dev/tty || answer=""
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    n|N|no|NO) return 1 ;;
    '') [ "$default" = "y" ] ;;
    *) return 1 ;;
  esac
}

ask_node_name() {
  if [ -n "$NAME" ]; then
    return
  fi

  if [ -r /dev/tty ] && [ -w /dev/tty ]; then
    while :; do
      printf "请为这台落地机起一个名字: " >/dev/tty
      IFS= read -r input_name </dev/tty || input_name=""
      input_name="$(printf "%s" "$input_name" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
      if [ -n "$input_name" ]; then
        NAME="$input_name"
        return
      fi
      echo "名称不能为空。" >/dev/tty
    done
  fi

  NAME="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo node)"
}

validate_port() {
  value="$1"
  label="$2"
  case "$value" in
    *[!0-9]*|'') die "无效${label}: $value" ;;
  esac
  if [ "$value" -lt 1 ] || [ "$value" -gt 65535 ]; then
    die "无效${label}: $value"
  fi
}

ask_port_value() {
  prompt="$1"
  default="$2"

  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    echo "$default"
    return
  fi

  while :; do
    printf "%s [%s]: " "$prompt" "$default" >/dev/tty
    IFS= read -r input_port </dev/tty || input_port=""
    input_port="$(printf "%s" "$input_port" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
    [ -n "$input_port" ] || input_port="$default"
    case "$input_port" in
      *[!0-9]*|'') echo "端口必须是 1-65535 的数字。" >/dev/tty ;;
      *)
        if [ "$input_port" -ge 1 ] && [ "$input_port" -le 65535 ]; then
          echo "$input_port"
          return
        fi
        echo "端口必须是 1-65535 的数字。" >/dev/tty
        ;;
    esac
  done
}

ask_server_host() {
  default="${1:-}"

  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    echo "$default"
    return
  fi

  while :; do
    if [ -n "$default" ]; then
      printf "检测到 Alpine/LXC，请输入落地机公网 IP 或域名 [%s]: " "$default" >/dev/tty
    else
      printf "检测到 Alpine/LXC，请输入落地机公网 IP 或域名: " >/dev/tty
    fi

    IFS= read -r input_host </dev/tty || input_host=""
    input_host="$(printf "%s" "$input_host" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
    [ -n "$input_host" ] || input_host="$default"

    case "$input_host" in
      *[[:space:]]*|'') echo "公网 IP 或域名不能为空，且不能包含空格。" >/dev/tty ;;
      *) echo "$input_host"; return ;;
    esac
  done
}

ask_hysteria_port() {
  if [ "$PORT_SET" -eq 0 ]; then
    PORT="$(ask_port_value "请输入 Hysteria2 监听 UDP 端口" "$PORT")"
  fi
  validate_port "$PORT" "监听端口"
}
ask_ss_port() {
 if [ "$SS_PORT_SET" -eq 0 ]; then
  SS_PORT="$(ask_port_value "请输入 Shadowsocks TCP 监听端口" "$SS_PORT")"
 fi
 validate_port "$SS_PORT" "Shadowsocks TCP 监听端口"
}
normalize_protocol() {
 case "$1" in
  hy2|hysteria|hysteria2|udp) echo hy2 ;;
  ss|shadowsocks|shadowsocks-tcp|tcp) echo ss ;;
  vless|reality|vless-reality)
   warn "Shadowsocks TCP TCP 已替换为 Shadowsocks TCP，继续使用 ss"
   echo ss
   ;;
  *) die "无效协议模式: $1，请使用 hy2 或 ss" ;;
 esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -n|--name)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      NAME="$2"
      shift 2
      ;;
    -c|--config)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      CONFIG="$2"
      shift 2
      ;;
    -p|--port)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      PORT="$2"
      PORT_SET=1
      shift 2
      ;;
    --vless-port)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SS_PORT="$2"
      SS_PORT_SET=1
      shift 2
      ;;
    --protocol|--mode)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      INSTALL_PROTOCOL="$(normalize_protocol "$2")"
      shift 2
      ;;
    --server)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SERVER="$2"
      shift 2
      ;;
    --password)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      PASSWORD="$2"
      shift 2
      ;;
    --sni)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SNI="$2"
      shift 2
      ;;
    --no-start)
      NO_START=1
      shift
      ;;
    --keep-deps)
      KEEP_DEPS=1
      shift
      ;;
    -y|--yes)
      YES=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "未知选项: $1"
      ;;
  esac
done

detect_pm() {
  if have apk; then
    echo apk
  elif have apt-get; then
    echo apt
  else
    echo unknown
  fi
}

install_packages() {
  pm="$(detect_pm)"
  case "$pm" in
    apk)
      apk add --no-cache "$@" >/dev/null
      ;;
    apt)
      apt-get update >/dev/null
      DEBIAN_FRONTEND=noninteractive apt-get install -y "$@" >/dev/null
      ;;
    *)
      die "不支持的包管理器，请手动安装依赖: $*"
      ;;
  esac
}

ensure_base_dependencies() {
  HAD_CURL=0
  HAD_PYTHON3=0
  HAD_OPENSSL=0
  have curl && HAD_CURL=1
  have python3 && HAD_PYTHON3=1
  have openssl && HAD_OPENSSL=1

  missing=""
  have curl || missing="$missing curl"
  have python3 || missing="$missing python3"
  have openssl || missing="$missing openssl"

  if [ -n "$missing" ]; then
    need_root
    echo "正在安装基础依赖:$missing" >&2
    install_packages $missing ca-certificates
  fi
}

remove_alpine_package_if_new() {
  pkg="$1"
  was_present="$2"

  if [ "$KEEP_DEPS" -eq 1 ] || [ "$was_present" -eq 1 ]; then
    return
  fi

  if have apk && apk info -e "$pkg" >/dev/null 2>&1; then
    apk del "$pkg" >/dev/null 2>&1 || true
  fi
}

cleanup_after_export() {
  rm -f /etc/s-box/certs/qie-hy2.crt /etc/s-box/certs/qie-hy2.key 2>/dev/null || true
  rmdir /etc/s-box/certs /etc/s-box 2>/dev/null || true

  if [ "$(detect_pm)" = "apk" ]; then
    remove_alpine_package_if_new curl "$HAD_CURL"
    remove_alpine_package_if_new python3 "$HAD_PYTHON3"
    remove_alpine_package_if_new openssl "$HAD_OPENSSL"
  fi
}

arch_name() {
  case "$(uname -m)" in
    x86_64|amd64) echo amd64 ;;
    aarch64|arm64) echo arm64 ;;
    armv7l|armv7*) echo armv7 ;;
    armv6l|armv6*) echo arm ;;
    i386|i686) echo 386 ;;
    *) die "不支持的架构: $(uname -m)" ;;
  esac
}

hysteria_bin() {
  if have hysteria; then
    command -v hysteria
    return
  fi
  if have hysteria2; then
    command -v hysteria2
    return
  fi
  if [ -x /usr/local/bin/hysteria ]; then
    echo /usr/local/bin/hysteria
    return
  fi
  return 1
}

install_hysteria_binary() {
  need_root
  arch="$(arch_name)"
  url="$(python3 - "$arch" <<'PY'
import json
import sys
import urllib.request

arch = sys.argv[1]
with urllib.request.urlopen('https://api.github.com/repos/apernet/hysteria/releases/latest', timeout=20) as r:
    data = json.load(r)

target = f'hysteria-linux-{arch}'
for asset in data.get('assets', []):
    if asset.get('name') == target:
        print(asset['browser_download_url'])
        break
else:
    raise SystemExit(f'未找到适用于 {arch} 的 Hysteria2 Linux 二进制')
PY
)"
  echo "正在安装 Hysteria2 二进制..." >&2
  curl -fsSL "$url" -o /usr/local/bin/hysteria
  chmod 755 /usr/local/bin/hysteria
}

singbox_bin() {
  if have sing-box; then
    command -v sing-box
    return
  fi
  if [ -x /usr/local/bin/sing-box ]; then
    echo /usr/local/bin/sing-box
    return
  fi
  return 1
}

install_singbox_binary() {
  need_root
  arch="$(arch_name)"
  url="$(python3 - "$arch" <<'PY'
import json
import sys
import urllib.request

arch = sys.argv[1]
with urllib.request.urlopen('https://api.github.com/repos/SagerNet/sing-box/releases/latest', timeout=20) as r:
    data = json.load(r)

suffix = f'linux-{arch}.tar.gz'
for asset in data.get('assets', []):
    name = asset.get('name', '')
    if name.endswith(suffix):
        print(asset['browser_download_url'])
        break
else:
    raise SystemExit(f'未找到适用于 {arch} 的 sing-box Linux 压缩包')
PY
)"
  tmp_dir="$(mktemp -d)"
  echo "正在安装 sing-box 二进制..." >&2
  curl -fsSL "$url" -o "$tmp_dir/sing-box.tar.gz"
  tar -xzf "$tmp_dir/sing-box.tar.gz" -C "$tmp_dir"
  bin_path="$(find "$tmp_dir" -type f -name sing-box | head -n 1)"
  [ -n "$bin_path" ] || die "sing-box 压缩包中未找到二进制文件"
  cp "$bin_path" /usr/local/bin/sing-box
  chmod 755 /usr/local/bin/sing-box
  rm -rf "$tmp_dir"
}

detect_server() {
  if [ -n "$SERVER" ]; then
    echo "$SERVER"
    return
  fi

  if [ "$(detect_pm)" = "apk" ]; then
    typed="$(ask_server_host "")"
    if [ -n "$typed" ]; then
      echo "$typed"
      return
    fi
    warn "Alpine/LXC 未输入公网 IP，尝试自动探测；如结果不正确，请使用 --server HOST。"
  fi

  for url in \
    https://api.ipify.org \
    https://ifconfig.me/ip \
    https://icanhazip.com
  do
    ip="$(curl -4fsSL --max-time 6 "$url" 2>/dev/null | tr -d ' \r\n' || true)"
    if [ -n "$ip" ]; then
      echo "$ip"
      return
    fi
  done

  host="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
  [ -n "$host" ] || die "无法自动检测公网 IP，请使用 --server HOST 指定"
  echo "$host"
}

singbox_exists() {
  if have sing-box; then
    return 0
  fi
  for path in /etc/s-box/sb.json /etc/sing-box/config.json /usr/local/etc/sing-box/config.json /etc/s-box/*.json /etc/sing-box/*.json; do
    [ -f "$path" ] && return 0
  done
  return 1
}

detect_existing_hy2() {
  out="$1"
  python3 - "$out" <<'PY'
import json
import os
import re
import ssl
import sys
from urllib.parse import urlparse

out = sys.argv[1]

def write(result):
    with open(out, 'w', encoding='utf-8', newline='\n') as f:
        json.dump(result, f, ensure_ascii=False)
        f.write('\n')

def read_text(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        return f.read()

def find_scalar(text, key_name):
    m = re.search(rf'(?m)^\s*{re.escape(key_name)}\s*:\s*["\']?([^"\'\n#]+)', text)
    return m.group(1).strip() if m else None

def clean_scalar(value):
    if value is None:
        return None
    value = str(value).strip().strip('"').strip("'")
    return value or None

def resolve_path(base, value):
    value = clean_scalar(value)
    if not value:
        return None
    if os.path.isabs(value):
        return value
    return os.path.abspath(os.path.join(os.path.dirname(base), value))

def cert_name(path):
    if not path or not os.path.isfile(path):
        return None
    try:
        cert = ssl._ssl._test_decode_cert(path)
    except Exception:
        return None

    for item in cert.get('subjectAltName', ()):
        if len(item) == 2 and item[0].lower() == 'dns' and item[1]:
            return item[1]

    for rdn in cert.get('subject', ()):
        for key, value in rdn:
            if key == 'commonName' and value:
                return value

    return None

def detect_hysteria_sni(path, text):
    for key in ('sni', 'serverName', 'servername', 'server_name'):
        value = clean_scalar(find_scalar(text, key))
        if value:
            return value

    cert_path = resolve_path(path, find_scalar(text, 'cert'))
    name = cert_name(cert_path)
    if name:
        return name

    domains = re.search(r'(?ms)^\s*domains\s*:\s*\n((?:\s*-\s*[^\n#]+\n?)+)', text)
    if domains:
        m = re.search(r'^\s*-\s*["\']?([^"\'\n#]+)', domains.group(1), re.M)
        if m:
            return clean_scalar(m.group(1))

    url = clean_scalar(find_scalar(text, 'url'))
    if url:
        parsed = urlparse(url)
        if parsed.hostname:
            return parsed.hostname

    return ''

def parse_hysteria_config(path):
    text = read_text(path)
    if not text.strip():
        return None
    password = find_scalar(text, 'password')
    listen = find_scalar(text, 'listen')
    if not password or not listen:
        return None
    m = re.search(r':(\d+)$', listen)
    if not m:
        return None
    return {
        'kind': 'hysteria',
        'path': path,
        'port': int(m.group(1)),
        'password': password,
        'sni': detect_hysteria_sni(path, text),
    }

def split_host_port(server_value):
    if not isinstance(server_value, str):
        return None, None
    s = server_value.strip()
    if s.startswith('[') and ']' in s:
        rest = s[s.index(']') + 1:]
        if rest.startswith(':'):
            try:
                return s[1:s.index(']')], int(rest[1:])
            except ValueError:
                return s[1:s.index(']')], None
    if ':' in s and s.count(':') == 1:
        host, port = s.rsplit(':', 1)
        try:
            return host, int(port)
        except ValueError:
            return s, None
    return s, None

def parse_singbox_config(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        data = json.load(f)
    for inbound in data.get('inbounds', []):
        if not isinstance(inbound, dict):
            continue
        if inbound.get('type') not in ('hysteria2', 'hy2'):
            continue
        port = inbound.get('listen_port')
        if port is None:
            _, port = split_host_port(inbound.get('listen'))
        try:
            port = int(port)
        except Exception:
            port = None
        password = inbound.get('password')
        users = inbound.get('users')
        if not password and isinstance(users, list):
            for user in users:
                if isinstance(user, dict) and user.get('password'):
                    password = user['password']
                    break
        sni = ''
        tls = inbound.get('tls')
        if isinstance(tls, dict):
            for key in ('server_name', 'serverName', 'sni'):
                if tls.get(key):
                    sni = str(tls[key]).strip()
                    break
        if port and password:
            return {'kind': 'sing-box', 'path': path, 'port': port, 'password': password, 'sni': sni}
    return None

hysteria_paths = ['/etc/hysteria/config.yaml', '/etc/hysteria/config.yml']
if os.path.isdir('/etc/hysteria'):
    for name in sorted(os.listdir('/etc/hysteria')):
        if name.endswith(('.yaml', '.yml')):
            hysteria_paths.append(os.path.join('/etc/hysteria', name))

seen = set()
for path in hysteria_paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    parsed = parse_hysteria_config(path)
    if parsed:
        write(parsed)
        raise SystemExit(0)

singbox_paths = ['/etc/s-box/sb.json', '/etc/sing-box/config.json', '/usr/local/etc/sing-box/config.json']
for base in ('/etc/s-box', '/etc/sing-box'):
    if os.path.isdir(base):
        for name in sorted(os.listdir(base)):
            if name.endswith('.json'):
                singbox_paths.append(os.path.join(base, name))

seen = set()
for path in singbox_paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    try:
        parsed = parse_singbox_config(path)
    except Exception as e:
        print(f'跳过无法读取的 sing-box 配置 {path}: {e}', file=sys.stderr)
        continue
    if parsed:
        write(parsed)
        raise SystemExit(0)

write({'kind': '', 'path': '', 'port': '', 'password': '', 'sni': ''})
raise SystemExit(2)
PY
}
detect_existing_shadowsocks() {
 out="$1"
 python3 - "$out" "$SS_META" <<'PY'
import json
import os
import sys

out, meta_path = sys.argv[1:3]
empty = {
    'kind': '',
    'path': '',
    'port': '',
    'method': '',
    'password': '',
}

def write(result):
    with open(out, 'w', encoding='utf-8', newline='\n') as f:
        json.dump(result, f, ensure_ascii=False)
        f.write('\n')

if not os.path.isfile(meta_path):
    write(empty)
    raise SystemExit(2)

try:
    with open(meta_path, 'r', encoding='utf-8-sig') as f:
        data = json.load(f)
except Exception:
    write(empty)
    raise SystemExit(2)

required = ('path', 'port', 'method', 'password')
if not all(data.get(k) for k in required):
    write(empty)
    raise SystemExit(2)

if not os.path.isfile(str(data.get('path'))):
    write(empty)
    raise SystemExit(2)

data['kind'] = 'shadowsocks'
write(data)
raise SystemExit(0)
PY
}

