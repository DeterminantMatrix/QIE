#!/bin/sh
set -eu

NAME=""
CONFIG="/etc/hysteria/config.yaml"
PORT="8443"
PORT_SET=0
SERVER=""
PASSWORD=""
SNI="qie.local"
INSTALL_PROTOCOL=""
NO_START=0
KEEP_DEPS=0
YES=0

SS_PORT="8388"
SS_PORT_SET=0
SS_METHOD="2022-blake3-aes-128-gcm"
SS_CONFIG="/etc/sing-box/qie-shadowsocks.json"
SS_META="/etc/sing-box/qie-shadowsocks.meta.json"
SS_SERVICE="qie-shadowsocks"
DEFAULT_HYSTERIA_VERSION="2.9.2"
DEFAULT_SING_BOX_VERSION="1.13.13"

usage() {
  cat <<'USAGE'
用法: luodi [选项]

选项:
  -n, --name NAME          qie 菜单中显示的节点名称
  -c, --config FILE        Hysteria2 服务端配置路径，默认 /etc/hysteria/config.yaml
  -p, --port PORT          Hysteria2 监听 UDP 端口，默认 8443
      --ss-port PORT       Shadowsocks TCP 监听端口，默认 8388
      --ss-method METHOD   Shadowsocks 加密方法，默认 2022-blake3-aes-128-gcm
      --protocol MODE      没有协议服务时安装的模式：hy2 或 ss
      --server HOST        原机器连接落地机时使用的公网地址/IP
      --password PASSWORD  Hysteria2 密码或 Shadowsocks 密码；不填则自动生成
      --sni NAME           Hysteria2 自签证书 SNI，默认 qie.local
      --no-start           写入配置和导出数据，但不重启/启动服务
      --keep-deps          保留本脚本安装的辅助依赖
  -y, --yes                非交互：自动安装缺失协议并导出
  -h, --help               显示帮助

在落地机上运行。本脚本会先显示检测结果；如果没有可用协议服务，
会让你选择 Hysteria2/UDP 或 Shadowsocks TCP。
USAGE
}

die() { echo "错误: $*" >&2; exit 1; }
warn() { echo "警告: $*" >&2; }
have() { command -v "$1" >/dev/null 2>&1; }
need_root() { [ "$(id -u)" -eq 0 ] || die "该操作需要 root 权限"; }

ask_yes_no() {
  prompt="$1"
  default="${2:-n}"
  auto="${3:-1}"
  if [ "$YES" -eq 1 ] && [ "$auto" -eq 1 ]; then
    echo "$prompt: 是（自动确认）" >&2
    return 0
  fi
  if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    [ "$default" = "y" ]
    return
  fi
  if [ "$default" = "y" ]; then
    printf "%s [Y/n]: " "$prompt" >/dev/tty
  else
    printf "%s [y/N]: " "$prompt" >/dev/tty
  fi
  IFS= read -r answer </dev/tty || answer=""
  case "$answer" in
    y|Y|yes|YES|Yes) return 0 ;;
    n|N|no|NO|No) return 1 ;;
    '') [ "$default" = "y" ] ;;
    *) return 1 ;;
  esac
}

ask_node_name() {
  if [ -n "$NAME" ]; then
    return
  fi
  default="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo node)"
  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    NAME="$default"
    return
  fi
  while :; do
    printf "请输入 qie 菜单中显示的节点名称 [%s]: " "$default" >/dev/tty
    IFS= read -r input_name </dev/tty || input_name=""
    case "$input_name" in
      '') NAME="$default"; return ;;
      *) NAME="$input_name"; return ;;
    esac
  done
}

validate_port() {
  value="$1"
  label="$2"
  case "$value" in
    *[!0-9]*|'') die "无效${label}: $value" ;;
  esac
  if [ "$value" -lt 1 ] || [ "$value" -gt 65535 ]; then
    die "无效${label}: $value"
  fi
}

ask_port_value() {
  prompt="$1"
  default="$2"
  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    echo "$default"
    return
  fi
  while :; do
    printf "%s [%s]: " "$prompt" "$default" >/dev/tty
    IFS= read -r input_port </dev/tty || input_port=""
    case "$input_port" in
      '') echo "$default"; return ;;
      *[!0-9]*) echo "端口必须是 1-65535 的数字。" >/dev/tty ;;
      *)
        if [ "$input_port" -ge 1 ] && [ "$input_port" -le 65535 ]; then
          echo "$input_port"
          return
        fi
        echo "端口必须是 1-65535 的数字。" >/dev/tty
        ;;
    esac
  done
}

ask_server_host() {
  default="${1:-}"
  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    echo "$default"
    return
  fi
  while :; do
    if [ -n "$default" ]; then
      printf "请输入落地机公网 IP 或域名 [%s]: " "$default" >/dev/tty
    else
      printf "请输入落地机公网 IP 或域名: " >/dev/tty
    fi
    IFS= read -r input_host </dev/tty || input_host=""
    case "$input_host" in
      '') [ -n "$default" ] && echo "$default" && return ;;
      *) echo "$input_host"; return ;;
    esac
  done
}

ask_hysteria_port() {
  if [ "$PORT_SET" -eq 0 ]; then
    PORT="$(ask_port_value "请输入 Hysteria2 监听 UDP 端口" "$PORT")"
  fi
  validate_port "$PORT" "监听端口"
}

ask_ss_port() {
  if [ "$SS_PORT_SET" -eq 0 ]; then
    SS_PORT="$(ask_port_value "请输入 Shadowsocks TCP 监听端口" "$SS_PORT")"
  fi
  validate_port "$SS_PORT" "Shadowsocks TCP 监听端口"
}

normalize_protocol() {
  case "$1" in
    hy2|hysteria|hysteria2|udp) echo hy2 ;;
    ss|shadowsocks|shadowsocks-tcp|tcp) echo ss ;;
    *) die "无效协议模式: $1，请使用 hy2 或 ss" ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -n|--name)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      NAME="$2"
      shift 2
      ;;
    -c|--config)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      CONFIG="$2"
      shift 2
      ;;
    -p|--port)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      PORT="$2"
      PORT_SET=1
      shift 2
      ;;
    --ss-port)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SS_PORT="$2"
      SS_PORT_SET=1
      shift 2
      ;;
    --ss-method)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SS_METHOD="$2"
      shift 2
      ;;
    --vless-port)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      warn "--vless-port 已废弃；本版本将其兼容为 --ss-port。"
      SS_PORT="$2"
      SS_PORT_SET=1
      shift 2
      ;;
    --reality-server)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      warn "--reality-server 已废弃；Shadowsocks TCP 不使用 Reality 握手域名。"
      shift 2
      ;;
    --protocol|--mode)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      INSTALL_PROTOCOL="$(normalize_protocol "$2")"
      shift 2
      ;;
    --server)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SERVER="$2"
      shift 2
      ;;
    --password)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      PASSWORD="$2"
      shift 2
      ;;
    --sni)
      [ "$#" -ge 2 ] || die "$1 需要参数值"
      SNI="$2"
      shift 2
      ;;
    --no-start)
      NO_START=1
      shift
      ;;
    --keep-deps)
      KEEP_DEPS=1
      shift
      ;;
    -y|--yes)
      YES=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *) die "未知选项: $1" ;;
  esac
done

detect_pm() {
  if have apk; then
    echo apk
  elif have apt-get; then
    echo apt
  else
    echo unknown
  fi
}

install_packages() {
  pm="$(detect_pm)"
  case "$pm" in
    apk) apk add --no-cache "$@" >/dev/null ;;
    apt)
      apt-get update >/dev/null
      DEBIAN_FRONTEND=noninteractive apt-get install -y "$@" >/dev/null
      ;;
    *) die "不支持的包管理器，请手动安装依赖: $*" ;;
  esac
}

ensure_base_dependencies() {
  HAD_CURL=0
  HAD_PYTHON3=0
  HAD_OPENSSL=0
  HAD_TAR=0
  have curl && HAD_CURL=1
  have python3 && HAD_PYTHON3=1
  have openssl && HAD_OPENSSL=1
  have tar && HAD_TAR=1

  missing=""
  have curl || missing="$missing curl"
  have python3 || missing="$missing python3"
  have openssl || missing="$missing openssl"
  have tar || missing="$missing tar"
  if [ -n "$missing" ]; then
    need_root
    echo "正在安装基础依赖:$missing" >&2
    install_packages $missing ca-certificates
  fi
}

remove_alpine_package_if_new() {
  pkg="$1"
  was_present="$2"
  if [ "$KEEP_DEPS" -eq 1 ] || [ "$was_present" -eq 1 ]; then
    return
  fi
  if have apk && apk info -e "$pkg" >/dev/null 2>&1; then
    apk del "$pkg" >/dev/null 2>&1 || true
  fi
}

cleanup_after_export() {
  if [ "$(detect_pm)" = "apk" ]; then
    remove_alpine_package_if_new curl "$HAD_CURL"
    remove_alpine_package_if_new python3 "$HAD_PYTHON3"
    remove_alpine_package_if_new openssl "$HAD_OPENSSL"
    remove_alpine_package_if_new tar "$HAD_TAR"
  fi
}

arch_name() {
  case "$(uname -m)" in
    x86_64|amd64) echo amd64 ;;
    aarch64|arm64) echo arm64 ;;
    armv7l|armv7*) echo armv7 ;;
    armv6l|armv6*) echo arm ;;
    i386|i686) echo 386 ;;
    *) die "不支持的架构: $(uname -m)" ;;
  esac
}

hysteria_bin() {
  if have hysteria; then command -v hysteria; return; fi
  if have hysteria2; then command -v hysteria2; return; fi
  if [ -x /usr/local/bin/hysteria ]; then echo /usr/local/bin/hysteria; return; fi
  return 1
}

install_hysteria_binary() {
  need_root
  arch="$(arch_name)"
  version="${HYSTERIA_VERSION:-$DEFAULT_HYSTERIA_VERSION}"
  url="${HYSTERIA_URL:-https://github.com/apernet/hysteria/releases/download/app/v${version}/hysteria-linux-${arch}}"
  echo "正在安装 Hysteria2 二进制..." >&2
  curl -fsSL "$url" -o /usr/local/bin/hysteria
  chmod 755 /usr/local/bin/hysteria
}

singbox_bin() {
  if have sing-box; then command -v sing-box; return; fi
  if [ -x /usr/local/bin/sing-box ]; then echo /usr/local/bin/sing-box; return; fi
  return 1
}

ensure_alpine_singbox_runtime() {
  bin="${1:-/usr/local/bin/sing-box}"
  [ "$(detect_pm)" = "apk" ] || return 0
  "$bin" version >/dev/null 2>&1 && return 0

  echo "检测到 Alpine，正在安装 sing-box 运行兼容依赖..." >&2
  apk add --no-cache gcompat libgcc >/dev/null 2>&1 || apk add --no-cache libc6-compat libgcc >/dev/null

  if [ "$(arch_name)" = "amd64" ] && [ ! -e /lib64/ld-linux-x86-64.so.2 ] && [ -e /lib/ld-linux-x86-64.so.2 ]; then
    mkdir -p /lib64
    ln -sf /lib/ld-linux-x86-64.so.2 /lib64/ld-linux-x86-64.so.2
  fi
}

install_singbox_binary() {
  need_root
  arch="$(arch_name)"
  version="${SING_BOX_VERSION:-$DEFAULT_SING_BOX_VERSION}"
  url="${SING_BOX_URL:-https://github.com/SagerNet/sing-box/releases/download/v${version}/sing-box-${version}-linux-${arch}.tar.gz}"
  tmp_dir="$(mktemp -d)"
  echo "正在安装 sing-box 二进制..." >&2
  curl -fsSL "$url" -o "$tmp_dir/sing-box.tar.gz"
  tar -xzf "$tmp_dir/sing-box.tar.gz" -C "$tmp_dir"
  bin_path="$(find "$tmp_dir" -type f -name sing-box | head -n 1)"
  [ -n "$bin_path" ] || die "sing-box 压缩包中未找到二进制文件"
  cp "$bin_path" /usr/local/bin/sing-box
  chmod 755 /usr/local/bin/sing-box
  rm -rf "$tmp_dir"
  ensure_alpine_singbox_runtime /usr/local/bin/sing-box
  /usr/local/bin/sing-box version >/dev/null 2>&1 || die "sing-box 已安装但无法运行；请检查系统架构或手动安装 glibc/gcompat 兼容库"
}

detect_server() {
  if [ -n "$SERVER" ]; then
    echo "$SERVER"
    return
  fi
  if [ "$(detect_pm)" = "apk" ]; then
    typed="$(ask_server_host "")"
    if [ -n "$typed" ]; then
      echo "$typed"
      return
    fi
    warn "Alpine/LXC 未输入公网 IP，尝试自动探测；如结果不正确，请使用 --server HOST。"
  fi
  for url in https://api.ipify.org https://ifconfig.me/ip https://icanhazip.com; do
    ip="$(curl -4fsSL --max-time 6 "$url" 2>/dev/null | tr -d ' \r\n' || true)"
    if [ -n "$ip" ]; then
      echo "$ip"
      return
    fi
  done
  host="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
  [ -n "$host" ] || die "无法自动检测公网 IP，请使用 --server HOST 指定"
  echo "$host"
}

json_field() {
  file="$1"
  key="$2"
  python3 - "$file" "$key" <<'PY'
import json
import sys
with open(sys.argv[1], 'r', encoding='utf-8-sig') as f:
    data = json.load(f)
value = data.get(sys.argv[2], '')
print(value)
PY
}

detect_existing_hy2() {
  out="$1"
  python3 - "$out" <<'PY'
import json
import os
import re
import ssl
import sys

out = sys.argv[1]

def write(result):
    with open(out, 'w', encoding='utf-8', newline='\n') as f:
        json.dump(result, f, ensure_ascii=False)
        f.write('\n')

def read_text(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        return f.read()

def find_scalar(text, key_name):
    m = re.search(rf'(?m)^\s*{re.escape(key_name)}\s*:\s*["\']?([^"\'\n#]+)', text)
    return m.group(1).strip() if m else None

def clean_scalar(value):
    if value is None:
        return None
    value = str(value).strip().strip('"').strip("'")
    return value or None

def resolve_path(base, value):
    value = clean_scalar(value)
    if not value:
        return None
    if os.path.isabs(value):
        return value
    return os.path.abspath(os.path.join(os.path.dirname(base), value))

def cert_name(path):
    if not path or not os.path.isfile(path):
        return None
    try:
        cert = ssl._ssl._test_decode_cert(path)
    except Exception:
        return None
    for item in cert.get('subjectAltName', ()):
        if len(item) == 2 and item[0].lower() == 'dns' and item[1]:
            return item[1]
    for rdn in cert.get('subject', ()):
        for key, value in rdn:
            if key == 'commonName' and value:
                return value
    return None

def split_host_port(server_value):
    if not isinstance(server_value, str):
        return None, None
    s = server_value.strip()
    if s.startswith('[') and ']' in s:
        rest = s[s.index(']') + 1:]
        if rest.startswith(':'):
            try:
                return s[1:s.index(']')], int(rest[1:])
            except ValueError:
                return s[1:s.index(']')], None
    if ':' in s and s.count(':') == 1:
        host, port = s.rsplit(':', 1)
        try:
            return host, int(port)
        except ValueError:
            return s, None
    return s, None

def detect_hysteria_sni(path, text):
    for key in ('sni', 'serverName', 'servername', 'server_name'):
        value = clean_scalar(find_scalar(text, key))
        if value:
            return value
    cert_path = resolve_path(path, find_scalar(text, 'cert'))
    name = cert_name(cert_path)
    if name:
        return name
    return ''

def parse_hysteria_config(path):
    text = read_text(path)
    if not text.strip():
        return None
    password = clean_scalar(find_scalar(text, 'password'))
    listen = clean_scalar(find_scalar(text, 'listen'))
    if not password or not listen:
        return None
    m = re.search(r':(\d+)$', listen)
    if not m:
        return None
    return {'kind': 'hysteria', 'path': path, 'port': int(m.group(1)), 'password': password, 'sni': detect_hysteria_sni(path, text)}

def parse_singbox_config(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        data = json.load(f)
    for inbound in data.get('inbounds', []):
        if not isinstance(inbound, dict):
            continue
        if inbound.get('type') not in ('hysteria2', 'hy2'):
            continue
        port = inbound.get('listen_port')
        if port is None:
            _, port = split_host_port(inbound.get('listen'))
        try:
            port = int(port)
        except Exception:
            port = None
        password = inbound.get('password')
        users = inbound.get('users')
        if not password and isinstance(users, list):
            for user in users:
                if isinstance(user, dict) and user.get('password'):
                    password = user['password']
                    break
        sni = ''
        tls = inbound.get('tls')
        if isinstance(tls, dict):
            for key in ('server_name', 'serverName', 'sni'):
                if tls.get(key):
                    sni = str(tls[key]).strip()
                    break
        if port and password:
            return {'kind': 'sing-box', 'path': path, 'port': port, 'password': password, 'sni': sni}
    return None

hysteria_paths = ['/etc/hysteria/config.yaml', '/etc/hysteria/config.yml']
if os.path.isdir('/etc/hysteria'):
    for name in sorted(os.listdir('/etc/hysteria')):
        if name.endswith(('.yaml', '.yml')):
            hysteria_paths.append(os.path.join('/etc/hysteria', name))
seen = set()
for path in hysteria_paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    parsed = parse_hysteria_config(path)
    if parsed:
        write(parsed)
        raise SystemExit(0)

singbox_paths = ['/etc/s-box/sb.json', '/etc/sing-box/config.json', '/usr/local/etc/sing-box/config.json']
for base in ('/etc/s-box', '/etc/sing-box'):
    if os.path.isdir(base):
        for name in sorted(os.listdir(base)):
            if name.endswith('.json'):
                singbox_paths.append(os.path.join(base, name))
seen = set()
for path in singbox_paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    try:
        parsed = parse_singbox_config(path)
    except Exception:
        continue
    if parsed:
        write(parsed)
        raise SystemExit(0)

write({'kind': '', 'path': '', 'port': '', 'password': '', 'sni': ''})
raise SystemExit(2)
PY
}

detect_existing_shadowsocks() {
  out="$1"
  python3 - "$out" "$SS_META" "$SS_CONFIG" <<'PY'
import json
import os
import sys

out, meta_path, config_path = sys.argv[1:4]
empty = {'kind': '', 'path': '', 'port': '', 'method': '', 'password': ''}

def write(result):
    with open(out, 'w', encoding='utf-8', newline='\n') as f:
        json.dump(result, f, ensure_ascii=False)
        f.write('\n')

def valid_meta(data):
    required = ('path', 'port', 'method', 'password')
    if not all(data.get(k) for k in required):
        return None
    if not os.path.isfile(str(data.get('path'))):
        return None
    try:
        data['port'] = int(data['port'])
    except Exception:
        return None
    data['kind'] = 'shadowsocks'
    return data

def parse_config(path):
    with open(path, 'r', encoding='utf-8-sig') as f:
        data = json.load(f)
    for inbound in data.get('inbounds', []):
        if not isinstance(inbound, dict):
            continue
        if inbound.get('type') != 'shadowsocks':
            continue
        port = inbound.get('listen_port')
        method = inbound.get('method')
        password = inbound.get('password')
        if port and method and password:
            return {
                'kind': 'shadowsocks',
                'path': path,
                'port': int(port),
                'method': method,
                'password': password,
            }
    return None

if os.path.isfile(meta_path):
    try:
        with open(meta_path, 'r', encoding='utf-8-sig') as f:
            meta = json.load(f)
        parsed = valid_meta(meta)
        if parsed:
            write(parsed)
            raise SystemExit(0)
    except SystemExit:
        raise
    except Exception:
        pass

paths = [config_path]
for base in ('/etc/sing-box', '/etc/s-box'):
    if os.path.isdir(base):
        for name in sorted(os.listdir(base)):
            if name.endswith('.json'):
                paths.append(os.path.join(base, name))
seen = set()
for path in paths:
    if path in seen or not os.path.isfile(path):
        continue
    seen.add(path)
    try:
        parsed = parse_config(path)
    except Exception:
        continue
    if parsed:
        write(parsed)
        raise SystemExit(0)

write(empty)
raise SystemExit(2)
PY
}

ensure_hysteria_service() {
  config="$1"
  bin="$2"
  if [ "$NO_START" -eq 1 ]; then
    echo "已设置 --no-start，跳过 Hysteria2 服务启动。" >&2
    return
  fi
  if have systemctl; then
    cat >/etc/systemd/system/hysteria-server.service <<EOF_SERVICE
[Unit]
Description=Hysteria2 Server
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=$bin server -c $config
Restart=on-failure
RestartSec=3
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF_SERVICE
    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl enable hysteria-server.service >/dev/null 2>&1 || true
    systemctl restart hysteria-server.service
    return
  fi
  if have rc-service; then
    cat >/etc/init.d/hysteria-server <<EOF_SERVICE
#!/sbin/openrc-run
name="hysteria-server"
command="$bin"
command_args="server -c $config"
command_background="yes"
pidfile="/run/hysteria-server.pid"
depend() {
  need net
}
EOF_SERVICE
    chmod +x /etc/init.d/hysteria-server
    rc-update add hysteria-server default >/dev/null 2>&1 || true
    rc-service hysteria-server restart
    return
  fi
  if have nohup; then
    nohup "$bin" server -c "$config" >/var/log/hysteria-server.log 2>&1 &
    echo "未找到服务管理器，已用后台进程启动 Hysteria2。" >&2
    return
  fi
  die "无法启动 Hysteria2：未找到 systemctl、rc-service 或可用的后台启动方式"
}

restart_hysteria_service() {
  if [ "$NO_START" -eq 1 ]; then
    echo "已设置 --no-start，跳过 Hysteria2 重启。" >&2
    return
  fi
  if have systemctl; then
    for svc in hysteria-server hysteria; do
      if systemctl cat "$svc.service" >/dev/null 2>&1; then
        systemctl restart "$svc.service"
        return
      fi
    done
  fi
  if have rc-service; then
    for svc in hysteria-server hysteria; do
      if [ -x "/etc/init.d/$svc" ]; then
        rc-service "$svc" restart
        return
      fi
    done
  fi
  if have service; then
    for svc in hysteria-server hysteria; do
      if service "$svc" status >/dev/null 2>&1; then
        service "$svc" restart
        return
      fi
    done
  fi
  warn "未找到可重启的 Hysteria2 服务，请手动重启。"
}

update_hysteria_port() {
  config="$1"
  new_port="$2"
  validate_port "$new_port" "监听端口"
  need_root
  python3 - "$config" "$new_port" <<'PY'
import re
import sys
from pathlib import Path
path = Path(sys.argv[1])
port = sys.argv[2]
text = path.read_text(encoding='utf-8-sig')
pattern = re.compile(r'(?m)^(\s*listen\s*:\s*)([^#\n]*?)(\s*#.*)?$')
def repl(match):
    return f'{match.group(1)}:{port}{match.group(3) or ""}'
new_text, count = pattern.subn(repl, text, count=1)
if count == 0:
    new_text = f'listen: :{port}\n' + text
path.write_text(new_text, encoding='utf-8', newline='\n')
PY
  restart_hysteria_service
}

create_hysteria_config() {
  if ! hysteria_bin >/dev/null 2>&1; then
    install_hysteria_binary
  fi
  HYSTERIA="$(hysteria_bin)"
  ask_hysteria_port
  need_root
  mkdir -p "$(dirname "$CONFIG")" /etc/hysteria/certs
  cert="/etc/hysteria/certs/qie-hy2.crt"
  key="/etc/hysteria/certs/qie-hy2.key"
  if [ ! -f "$cert" ] || [ ! -f "$key" ]; then
    echo "正在生成自签 TLS 证书..." >&2
    openssl req -x509 -newkey rsa:2048 -keyout "$key" -out "$cert" -days 3650 -nodes -subj "/CN=$SNI" >/dev/null 2>&1
    chmod 600 "$key"
  fi
  if [ -z "$PASSWORD" ]; then
    PASSWORD="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(24))
PY
)"
  fi
  cat >"$CONFIG" <<EOF_HY2
listen: :$PORT

tls:
  cert: $cert
  key: $key

auth:
  type: password
  password: $PASSWORD
EOF_HY2
  ensure_hysteria_service "$CONFIG" "$HYSTERIA"
}

ensure_singbox_service() {
  config="$1"
  bin="$2"
  if [ "$NO_START" -eq 1 ]; then
    echo "已设置 --no-start，跳过 Shadowsocks TCP 服务启动。" >&2
    return
  fi
  if have systemctl; then
    cat >/etc/systemd/system/${SS_SERVICE}.service <<EOF_SERVICE
[Unit]
Description=QIE Shadowsocks TCP
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=$bin run -c $config
Restart=on-failure
RestartSec=3
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF_SERVICE
    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl enable ${SS_SERVICE}.service >/dev/null 2>&1 || true
    systemctl restart ${SS_SERVICE}.service
    return
  fi
  if have rc-service; then
    cat >/etc/init.d/${SS_SERVICE} <<EOF_SERVICE
#!/sbin/openrc-run
name="$SS_SERVICE"
command="$bin"
command_args="run -c $config"
command_background="yes"
pidfile="/run/$SS_SERVICE.pid"
depend() {
  need net
}
EOF_SERVICE
    chmod +x /etc/init.d/${SS_SERVICE}
    rc-update add ${SS_SERVICE} default >/dev/null 2>&1 || true
    rc-service ${SS_SERVICE} restart
    return
  fi
  if have nohup; then
    nohup "$bin" run -c "$config" >/var/log/${SS_SERVICE}.log 2>&1 &
    echo "未找到服务管理器，已用后台进程启动 Shadowsocks TCP。" >&2
    return
  fi
  die "无法启动 Shadowsocks TCP：未找到 systemctl、rc-service 或可用的后台启动方式"
}

generate_ss_password() {
  if singbox_bin >/dev/null 2>&1; then
    sb="$(singbox_bin)"
    if "$sb" generate rand --base64 16 >/dev/null 2>&1; then
      "$sb" generate rand --base64 16
      return
    fi
  fi
  python3 - <<'PY'
import base64
import secrets
print(base64.b64encode(secrets.token_bytes(16)).decode())
PY
}

create_shadowsocks_config() {
  if ! singbox_bin >/dev/null 2>&1; then
    install_singbox_binary
  fi
  SINGBOX="$(singbox_bin)"
  ensure_alpine_singbox_runtime "$SINGBOX"
  "$SINGBOX" version >/dev/null 2>&1 || die "sing-box 已存在但无法运行；请检查系统架构或手动安装 glibc/gcompat 兼容库"
  ask_ss_port
  need_root
  mkdir -p "$(dirname "$SS_CONFIG")"
  if [ -z "$PASSWORD" ]; then
    PASSWORD="$(generate_ss_password)"
  fi
  python3 - "$SS_CONFIG" "$SS_META" "$SS_PORT" "$SS_METHOD" "$PASSWORD" <<'PY'
import json
import sys
config_path, meta_path, port, method, password = sys.argv[1:]
port = int(port)
config = {
    'log': {'level': 'info'},
    'inbounds': [
        {
            'type': 'shadowsocks',
            'tag': 'ss-in',
            'listen': '0.0.0.0',
            'listen_port': port,
            'method': method,
            'password': password,
            'network': 'tcp',
        }
    ],
    'outbounds': [
        {'type': 'direct', 'tag': 'direct'}
    ],
    'route': {'final': 'direct'},
}
meta = {
    'kind': 'shadowsocks',
    'path': config_path,
    'port': port,
    'method': method,
    'password': password,
}
with open(config_path, 'w', encoding='utf-8', newline='\n') as f:
    json.dump(config, f, ensure_ascii=False, indent=2)
    f.write('\n')
with open(meta_path, 'w', encoding='utf-8', newline='\n') as f:
    json.dump(meta, f, ensure_ascii=False, indent=2)
    f.write('\n')
PY
  "$SINGBOX" check -c "$SS_CONFIG" >/dev/null
  ensure_singbox_service "$SS_CONFIG" "$SINGBOX"
}

choose_install_protocol() {
  if [ -n "$INSTALL_PROTOCOL" ]; then
    echo "$INSTALL_PROTOCOL"
    return
  fi
  if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    echo hy2
    return
  fi
  while :; do
    echo "未检测到可用协议服务，请选择安装模式：" >/dev/tty
    echo " 1) Hysteria2 / UDP" >/dev/tty
    echo " 2) Shadowsocks / TCP" >/dev/tty
    printf "请选择 [1/2，默认 1]: " >/dev/tty
    IFS= read -r answer </dev/tty || answer=""
    case "$answer" in
      ''|1) echo hy2; return ;;
      2) echo ss; return ;;
      *) echo "请输入 1 或 2。" >/dev/tty ;;
    esac
  done
}

choose_export_protocol() {
  if [ "$HY2_EXISTS" -eq 1 ] && [ "$SS_EXISTS" -eq 1 ]; then
    if [ "$YES" -eq 1 ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
      if [ -n "$INSTALL_PROTOCOL" ]; then
        echo "$INSTALL_PROTOCOL"
      else
        echo hy2
      fi
      return
    fi
    while :; do
      echo "检测到多个可导出的协议，请选择导出：" >/dev/tty
      echo " 1) Hysteria2 / UDP" >/dev/tty
      echo " 2) Shadowsocks / TCP" >/dev/tty
      printf "请选择 [1/2，默认 1]: " >/dev/tty
      IFS= read -r answer </dev/tty || answer=""
      case "$answer" in
        ''|1) echo hy2; return ;;
        2) echo ss; return ;;
        *) echo "请输入 1 或 2。" >/dev/tty ;;
      esac
    done
  elif [ "$HY2_EXISTS" -eq 1 ]; then
    echo hy2
  elif [ "$SS_EXISTS" -eq 1 ]; then
    echo ss
  else
    echo ""
  fi
}

emit_node_block() {
  payload_file="$1"
  python3 - "$payload_file" <<'PY'
import base64
import json
import sys
with open(sys.argv[1], 'r', encoding='utf-8-sig') as f:
    data = json.load(f)
raw = json.dumps(data, ensure_ascii=False, separators=(',', ':')).encode('utf-8')
print('QIE_NODE_BEGIN')
print(base64.b64encode(raw).decode('ascii'))
print('QIE_NODE_END')
PY
}

