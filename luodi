emit_shadowsocks_export() {
 source_path="$1"
 port="$2"
 if [ "$#" -eq 7 ]; then
  # Backward-compatible call shape after the old VLESS export call has been renamed.
  method="$(json_field "$SS_INFO" method)"
  password="$(json_field "$SS_INFO" password)"
  out="$7"
 else
  method="$3"
  password="$4"
  out="$5"
 fi
 python3 - "$SERVER" "$NAME" "$source_path" "$port" "$method" "$password" "$out" <<'PY'
import base64
import json
import socket
import sys
import time

server, name, source_path, port, method, password, out = sys.argv[1:]
port = int(port)
client_config = {
    'log': {'level': 'info'},
    'inbounds': [
        {
            'type': 'mixed',
            'tag': 'mixed-in',
            'listen': '127.0.0.1',
